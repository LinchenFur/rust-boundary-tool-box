import { ScrollView } from "std-widgets.slint";
import { Action, DetailRow, Panel, TextField, TitleBlock, Txt } from "../components.slint";
import { I18n } from "../i18n.slint";

component SettingsSection inherits Rectangle {
    in property <string> title;
    in property <string> sub: "";

    height: sub == "" ? 30px : 44px;
    background: #00000000;

    VerticalLayout {
        alignment: start;
        spacing: 2px;

        Txt {
            text: title;
            color: #eef4fb;
            font-size: 20px;
            font-weight: 800;
        }

        if sub != "" : Txt {
            text: sub;
            color: #95a3b8;
            font-size: 11px;
            font-weight: 600;
            wrap: char-wrap;
        }
    }
}

component LanguageChoice inherits Rectangle {
    in property <int> code;
    in property <int> language-mode;
    in property <image> flag;
    in property <brush> accent: #62e2c1;
    callback clicked();

    property <bool> selected: language-mode == code;
    property <bool> enabled-state: language-mode != code;

    height: 50px;
    border-radius: 14px;
    border-width: 1px;
    border-color: selected ? accent : (touch.has-hover ? #54617a : #344056);
    background: selected ? #10241f : (touch.has-hover ? #1d2531 : #0f131a);

    animate background { duration: 140ms; }
    animate border-color { duration: 140ms; }

    Image {
        width: min(parent.width - 18px, 58px);
        height: 32px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: flag;
        image-fit: contain;
    }

    touch := TouchArea {
        enabled: root.enabled-state;
        clicked => { root.clicked(); }
    }
}

component AutoLanguageChoice inherits Rectangle {
    in property <int> language-mode;
    in property <brush> accent: #f6c76d;
    callback clicked();

    property <bool> selected: language-mode == -1;
    property <bool> enabled-state: language-mode != -1;

    height: 50px;
    border-radius: 14px;
    border-width: 1px;
    border-color: selected ? accent : (touch.has-hover ? #54617a : #344056);
    background: selected ? #241b10 : (touch.has-hover ? #1d2531 : #0f131a);

    animate background { duration: 140ms; }
    animate border-color { duration: 140ms; }

    Txt {
        text: I18n.language-name(-1);
        color: selected ? #ffe0a3 : #c7d1df;
        font-size: 13px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        wrap: no-wrap;
    }

    touch := TouchArea {
        enabled: root.enabled-state;
        clicked => { root.clicked(); }
    }
}

export component SettingsPage inherits Rectangle {
    in property <bool> busy;
    in property <bool> has_target;
    in property <string> status_text;
    in property <string> target_text;
    in property <string> process_status_text;
    in property <string> system_status_text;
    in property <bool> system_status_warning;
    in property <string> server_status_text;
    in property <bool> update_checking;
    in property <string> update_status_text;
    in-out property <string> github_proxy_text;
    in property <bool> github_proxy_loading;
    in property <string> github_proxy_status_text;
    in property <int> language;
    in property <int> language_mode;
    callback open_logs_clicked();
    callback check_updates_clicked();
    callback github_proxy_changed(proxy: string);
    callback open_github_proxy_dialog_clicked();
    callback refresh_github_proxies_clicked();
    callback language_changed(language: int);

    // 页面 3：工具状态和日志入口。
    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        spacing: 16px;

        Panel {
            width: 360px;
            vertical-stretch: 1;
            radius: 26px;

            ScrollView {
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: form.height;

                form := Rectangle {
                    width: parent.width - 14px;
                    height: 610px;
                    background: #00000000;

                    VerticalLayout {
                        width: parent.width;
                        height: parent.height;
                        padding: 24px;
                        spacing: 12px;

                        TitleBlock {
                            title: I18n.tr("设置", "Settings", "設定");
                            sub: I18n.tr("更新、代理、语言与日志", "Updates, proxy, language, and logs", "更新、プロキシ、言語、ログ");
                        }

                        Action {
                            label: update_checking
                                ? I18n.tr("检查中", "Checking", "確認中")
                                : I18n.tr("检查更新", "Check Updates", "更新を確認");
                            sub: update_status_text;
                            enabled: !busy && !update_checking;
                            accent: #62e2c1;
                            clicked => { root.check_updates_clicked(); }
                        }

                        Action {
                            label: I18n.tr("打开日志目录", "Open Log Folder", "ログフォルダーを開く");
                            sub: I18n.tr("查看工具运行记录", "View toolbox runtime logs", "ツールの実行ログを表示");
                            enabled: !busy;
                            accent: #a8d8ff;
                            clicked => { root.open_logs_clicked(); }
                        }

                        SettingsSection {
                            title: I18n.tr("下载代理", "Download Proxy", "ダウンロードプロキシ");
                            sub: github_proxy_status_text;
                        }

                        Action {
                            label: I18n.tr("选择代理节点", "Select Proxy Node", "プロキシノードを選択");
                            sub: github_proxy_text == "" ? I18n.tr("直连 GitHub", "Direct GitHub", "GitHub へ直接接続") : github_proxy_text;
                            enabled: !busy && !github_proxy_loading;
                            accent: #62e2c1;
                            clicked => { root.open_github_proxy_dialog_clicked(); }
                        }

                        TextField {
                            text <=> root.github_proxy_text;
                            placeholder: "https://git-proxy.cubland.icu/";
                            enabled: !busy;
                            edited(text) => { root.github_proxy_changed(text); }
                        }

                        Action {
                            label: github_proxy_loading ? I18n.tr("刷新并测速中", "Refreshing and Testing", "更新と測定中") : I18n.tr("刷新代理列表", "Refresh Proxy List", "プロキシ一覧を更新");
                            sub: I18n.tr("重新获取节点并测试延迟", "Fetch nodes and test latency", "ノードを取得して遅延を測定");
                            enabled: !busy && !github_proxy_loading;
                            accent: #a8d8ff;
                            clicked => { root.refresh_github_proxies_clicked(); }
                        }

                        SettingsSection {
                            title: I18n.tr("语言", "Language", "言語");
                            sub: I18n.tr("跟随系统或手动选择", "Follow system or choose manually", "システムに追従または手動選択");
                        }

                        HorizontalLayout {
                            height: 50px;
                            spacing: 10px;

                            AutoLanguageChoice {
                                horizontal-stretch: 1;
                                language-mode: root.language_mode;
                                clicked => { root.language_changed(-1); }
                            }

                            LanguageChoice {
                                horizontal-stretch: 1;
                                code: 0;
                                language-mode: root.language_mode;
                                flag: @image-url("../assets/flag-cn.svg");
                                accent: #d7c4ff;
                                clicked => { root.language_changed(0); }
                            }

                            LanguageChoice {
                                horizontal-stretch: 1;
                                code: 1;
                                language-mode: root.language_mode;
                                flag: @image-url("../assets/flag-us.svg");
                                accent: #a8d8ff;
                                clicked => { root.language_changed(1); }
                            }

                            LanguageChoice {
                                horizontal-stretch: 1;
                                code: 2;
                                language-mode: root.language_mode;
                                flag: @image-url("../assets/flag-jp.svg");
                                accent: #9ef0b5;
                                clicked => { root.language_changed(2); }
                            }
                        }
                    }
                }
            }
        }

        Panel {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            radius: 26px;

            ScrollView {
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: state-form.height;

                state-form := Rectangle {
                    width: parent.width - 14px;
                    height: max(690px, parent.height);
                    background: #00000000;

                    VerticalLayout {
                        width: parent.width;
                        height: parent.height;
                        padding: 24px;
                        spacing: 16px;

                        TitleBlock {
                            title: I18n.tr("详细状态", "Detailed Status", "詳細状態");
                            sub: I18n.tr("当前目标、进程、系统与服务状态", "Target, process, system, and service state", "対象、プロセス、システム、サービス状態");
                        }

                        DetailRow {
                            label: I18n.tr("操作状态", "Action Status", "操作状態");
                            value: status_text;
                            accent: busy ? #ffb4ab : #9ef0b5;
                        }

                        DetailRow {
                            label: I18n.tr("目标目录", "Target Path", "対象パス");
                            value: has_target ? target_text : I18n.tr("未锁定游戏根目录", "Game root is not locked", "ゲームルート未設定");
                            accent: has_target ? #9ef0b5 : #f6c76d;
                        }

                        DetailRow {
                            label: I18n.tr("进程状态", "Process Status", "プロセス状態");
                            value: process_status_text;
                            accent: #d7c4ff;
                        }

                        DetailRow {
                            row-height: 118px;
                            label: I18n.tr("系统检查", "System Check", "システムチェック");
                            value: system_status_text;
                            accent: system_status_warning ? #ffb4ab : #9ef0b5;
                        }

                        DetailRow {
                            label: I18n.tr("更新状态", "Update Status", "更新状態");
                            value: update_status_text;
                            accent: update_checking ? #f6c76d : #62e2c1;
                        }

                        DetailRow {
                            label: I18n.tr("服务器列表", "Server List", "サーバー一覧");
                            value: server_status_text;
                            accent: #a8d8ff;
                        }
                    }
                }
            }
        }
    }
}
