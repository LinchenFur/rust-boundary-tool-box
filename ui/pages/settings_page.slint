import { Action, DetailRow, Panel, TitleBlock } from "../components.slint";

export component SettingsPage inherits Rectangle {
    in property <bool> busy;
    in property <bool> has_target;
    in property <string> status_text;
    in property <string> target_text;
    in property <string> process_status_text;
    in property <string> server_status_text;
    in property <bool> update_checking;
    in property <string> update_status_text;
    callback open_logs_clicked();
    callback check_updates_clicked();

    // 页面 3：工具状态和日志入口。
    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        spacing: 16px;

        Panel {
            width: 360px;
            vertical-stretch: 1;
            radius: 26px;

            VerticalLayout {
                padding: 24px;
                spacing: 16px;

                TitleBlock {
                    title: "设置";
                    sub: "工具运行记录与当前状态";
                }

                Action {
                    label: update_checking ? "检查中" : "检查更新";
                    sub: update_status_text;
                    enabled: !busy && !update_checking;
                    accent: #62e2c1;
                    clicked => { root.check_updates_clicked(); }
                }

                Action {
                    label: "打开日志目录";
                    sub: "查看工具运行记录";
                    enabled: !busy;
                    accent: #a8d8ff;
                    clicked => { root.open_logs_clicked(); }
                }
            }
        }

        Panel {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            radius: 26px;

            VerticalLayout {
                padding: 24px;
                spacing: 16px;

                TitleBlock {
                    title: "详细状态";
                    sub: "当前目标、进程与服务状态";
                }

                DetailRow {
                    label: "操作状态";
                    value: status_text;
                    accent: busy ? #ffb4ab : #9ef0b5;
                }

                DetailRow {
                    label: "目标目录";
                    value: has_target ? target_text : "未锁定游戏根目录";
                    accent: has_target ? #9ef0b5 : #f6c76d;
                }

                DetailRow {
                    label: "进程状态";
                    value: process_status_text;
                    accent: #d7c4ff;
                }

                DetailRow {
                    label: "更新状态";
                    value: update_status_text;
                    accent: update_checking ? #f6c76d : #62e2c1;
                }

                DetailRow {
                    label: "服务器列表";
                    value: server_status_text;
                    accent: #a8d8ff;
                }
            }
        }
    }
}
