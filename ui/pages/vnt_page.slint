import { ListView, ScrollView } from "std-widgets.slint";
import { VntPeerRow, VntServerRow } from "../models.slint";
import { Action, InfoBox, OptionSwitch, Panel, ServerDropdown, TextField, TitleBlock, Txt } from "../components.slint";
import { VntPeerLine, VntServerLine } from "../rows.slint";
import { I18n } from "../i18n.slint";

export component VntPage inherits Rectangle {
    private property <bool> page_locked: true;
    in-out property <string> vnt_server_text;
    in-out property <string> vnt_new_server_text;
    in property <[string]> vnt_server_options;
    in-out property <string> vnt_network_code;
    in-out property <string> vnt_password;
    in-out property <bool> vnt_no_tun;
    in-out property <bool> vnt_compress;
    in-out property <bool> vnt_rtx;
    in property <bool> vnt_busy;
    in property <bool> vnt_running;
    in property <string> vnt_status_text;
    in property <string> vnt_detail_text;
    in property <string> vnt_ip_text;
    in property <string> vnt_server_status_text;
    in property <string> vnt_nat_text;
    in property <string> vnt_peer_summary_text;
    in property <[VntServerRow]> vnt_server_rows;
    in property <[VntPeerRow]> vnt_peer_rows;
    callback vnt_start_clicked();
    callback vnt_stop_clicked();
    callback vnt_refresh_clicked();
    callback vnt_add_server_clicked(address: string);
    callback vnt_settings_changed();

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        spacing: 16px;

        Panel {
            width: 420px;
            vertical-stretch: 1;
            radius: 26px;

            VerticalLayout {
                padding: 22px;
                spacing: 12px;

                TitleBlock {
                    title: I18n.tr("联机", "Network", "ネットワーク");
                    sub: vnt_running
                        ? I18n.tr("虚拟局域网已运行", "Virtual LAN is running", "仮想 LAN は実行中")
                        : I18n.tr("创建或加入同一个网络编号", "Create or join the same network code", "同じネットワーク番号を作成または参加");
                }

                InfoBox {
                    box-height: 78px;
                    label: I18n.tr("状态", "STATUS", "状態");
                    value: vnt_status_text + "\n" + vnt_detail_text;
                    accent: vnt_running ? #9ef0b5 : (vnt_busy ? #f6c76d : #a8d8ff);
                }

                ScrollView {
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    viewport-height: form.height;

                    form := Rectangle {
                        width: parent.width - 14px;
                        height: 390px;
                        background: #00000000;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            spacing: 8px;

                            Txt {
                                text: I18n.tr("服务器地址", "Server Address", "サーバーアドレス");
                                color: #95a3b8;
                                font-size: 12px;
                                font-weight: 700;
                            }

                            ServerDropdown {
                                value <=> root.vnt_server_text;
                                options: root.vnt_server_options;
                                enabled: !vnt_running && !vnt_busy;
                                selected(value) => {
                                    root.vnt_server_text = value;
                                    root.vnt_settings_changed();
                                }
                            }

                            HorizontalLayout {
                                height: 46px;
                                spacing: 10px;

                                TextField {
                                    horizontal-stretch: 1;
                                    text <=> root.vnt_new_server_text;
                                    placeholder: I18n.tr("输入自定义服务器地址", "Enter a custom server address", "カスタムサーバーアドレスを入力");
                                    enabled: !vnt_running && !vnt_busy;
                                    accepted => {
                                        if root.vnt_new_server_text != "" {
                                            root.vnt_add_server_clicked(root.vnt_new_server_text);
                                        }
                                    }
                                }

                                Action {
                                    width: 86px;
                                    height: 46px;
                                    label: I18n.tr("添加", "Add", "追加");
                                    sub: "";
                                    enabled: !vnt_running && !vnt_busy && vnt_new_server_text != "";
                                    accent: #62e2c1;
                                    clicked => {
                                        if root.vnt_new_server_text != "" {
                                            root.vnt_add_server_clicked(root.vnt_new_server_text);
                                        }
                                    }
                                }
                            }

                            Txt {
                                text: I18n.tr("网络编号", "Network Code", "ネットワーク番号");
                                color: #95a3b8;
                                font-size: 12px;
                                font-weight: 700;
                            }

                            TextField {
                                text <=> root.vnt_network_code;
                                placeholder: I18n.tr("相同编号会进入同一虚拟局域网", "Same code joins the same virtual LAN", "同じ番号で同じ仮想 LAN に参加");
                                enabled: !vnt_running && !vnt_busy;
                                edited(text) => {
                                    root.vnt_network_code = text;
                                    root.vnt_settings_changed();
                                }
                            }

                            Txt {
                                text: I18n.tr("加密密码", "Encryption Password", "暗号化パスワード");
                                color: #95a3b8;
                                font-size: 12px;
                                font-weight: 700;
                            }

                            TextField {
                                text <=> root.vnt_password;
                                placeholder: I18n.tr("可选", "Optional", "任意");
                                enabled: !vnt_running && !vnt_busy;
                                input-type: InputType.password;
                                edited(text) => {
                                    root.vnt_password = text;
                                    root.vnt_settings_changed();
                                }
                            }

                            VerticalLayout {
                                height: 104px;
                                spacing: 8px;

                                OptionSwitch {
                                    enabled: !vnt_running && !vnt_busy;
                                    checked: vnt_no_tun;
                                    on-label: I18n.tr("端口模式", "Port Mode", "ポートモード");
                                    off-label: I18n.tr("虚拟网卡模式", "Virtual Adapter", "仮想アダプター");
                                    sub: vnt_no_tun
                                        ? I18n.tr("不创建虚拟网卡", "No virtual adapter", "仮想アダプターを作成しない")
                                        : I18n.tr("游戏局域网联机", "Game LAN networking", "ゲーム LAN 接続");
                                    toggled(value) => {
                                        root.vnt_no_tun = value;
                                        root.vnt_settings_changed();
                                    }
                                }

                                HorizontalLayout {
                                    height: 48px;
                                    spacing: 8px;

                                    OptionSwitch {
                                        horizontal-stretch: 1;
                                        enabled: !vnt_running && !vnt_busy;
                                        checked: vnt_compress;
                                        on-label: I18n.tr("压缩传输", "Compression", "圧縮転送");
                                        off-label: I18n.tr("压缩传输", "Compression", "圧縮転送");
                                        sub: vnt_compress
                                            ? I18n.tr("已开启", "Enabled", "有効")
                                            : I18n.tr("弱网可开启", "Useful on weak networks", "不安定な回線で有効");
                                        toggled(value) => {
                                            root.vnt_compress = value;
                                            root.vnt_settings_changed();
                                        }
                                    }

                                    OptionSwitch {
                                        horizontal-stretch: 1;
                                        enabled: !vnt_running && !vnt_busy;
                                        checked: vnt_rtx;
                                        on-label: I18n.tr("QUIC 通道", "QUIC Channel", "QUIC チャネル");
                                        off-label: I18n.tr("QUIC 通道", "QUIC Channel", "QUIC チャネル");
                                        sub: vnt_rtx
                                            ? I18n.tr("已开启", "Enabled", "有効")
                                            : I18n.tr("高丢包可开", "Use on high packet loss", "パケットロスが多い時に使用");
                                        toggled(value) => {
                                            root.vnt_rtx = value;
                                            root.vnt_settings_changed();
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    height: 58px;
                    spacing: 12px;

                    Action {
                        horizontal-stretch: 1;
                        label: vnt_running
                            ? I18n.tr("运行中", "Running", "実行中")
                            : (vnt_busy ? I18n.tr("启动中", "Starting", "起動中") : I18n.tr("启动联机", "Start Network", "ネットワーク開始"));
                        sub: vnt_running ? I18n.tr("网络已建立", "Network established", "ネットワーク確立済み") : I18n.tr("开始", "START", "開始");
                        enabled: !vnt_running && !vnt_busy;
                        primary: false;
                        accent: #62e2c1;
                        clicked => { root.vnt_start_clicked(); }
                    }

                    Action {
                        width: 128px;
                        label: vnt_busy ? I18n.tr("处理中", "Working", "処理中") : I18n.tr("停止", "Stop", "停止");
                        sub: "";
                        enabled: vnt_running && !vnt_busy;
                        accent: #ffb4ab;
                        clicked => { root.vnt_stop_clicked(); }
                    }
                }
            }
        }

        Panel {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            radius: 26px;

            VerticalLayout {
                padding: 24px;
                spacing: 14px;

                HorizontalLayout {
                    height: 50px;
                    spacing: 12px;

                    TitleBlock {
                        horizontal-stretch: 1;
                        title: I18n.tr("联机状态", "Network Status", "ネットワーク状態");
                        sub: vnt_peer_summary_text;
                    }

                    Action {
                        width: 132px;
                        label: I18n.tr("刷新", "Refresh", "更新");
                        sub: "";
                        enabled: vnt_running && !vnt_busy;
                        accent: #a8d8ff;
                        clicked => { root.vnt_refresh_clicked(); }
                    }
                }

                HorizontalLayout {
                    height: 76px;
                    spacing: 12px;

                    InfoBox {
                        horizontal-stretch: 1;
                        box-height: 76px;
                        label: I18n.tr("虚拟 IP", "VIRTUAL IP", "仮想 IP");
                        value: vnt_ip_text;
                        accent: vnt_running ? #9ef0b5 : #54617a;
                    }

                    InfoBox {
                        horizontal-stretch: 1;
                        box-height: 76px;
                        label: I18n.tr("服务器", "SERVER", "サーバー");
                        value: vnt_server_status_text;
                        accent: vnt_running ? #a8d8ff : #54617a;
                    }
                }

                HorizontalLayout {
                    height: 76px;
                    spacing: 12px;

                    InfoBox {
                        horizontal-stretch: 1;
                        box-height: 76px;
                        label: I18n.tr("网络", "NETWORK", "ネットワーク");
                        value: vnt_network_code == "" ? "-" : vnt_network_code;
                        accent: #d7c4ff;
                    }

                    InfoBox {
                        horizontal-stretch: 1;
                        box-height: 76px;
                        label: I18n.tr("NAT 类型", "NAT", "NAT 種別");
                        value: vnt_nat_text;
                        accent: #f6c76d;
                    }
                }

                VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 12px;

                    Panel {
                        height: 190px;
                        fill: #0f131a;
                        radius: 18px;

                        VerticalLayout {
                            padding: 14px;
                            spacing: 8px;

                            HorizontalLayout {
                                height: 34px;
                                spacing: 12px;

                                Txt {
                                    text: I18n.tr("VNT 服务器", "VNT Servers", "VNT サーバー");
                                    color: #eef4fb;
                                    font-size: 18px;
                                    font-weight: 800;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }

                                Txt {
                                    text: vnt_server_status_text;
                                    color: #95a3b8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                            }

                            ListView {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;

                                for server in vnt_server_rows: VntServerLine {
                                    name: server.name;
                                    address: server.address;
                                    detail: server.detail;
                                    online: server.online;
                                }
                            }
                        }
                    }

                    Panel {
                        vertical-stretch: 1;
                        fill: #0f131a;
                        radius: 18px;

                        VerticalLayout {
                            padding: 14px;
                            spacing: 8px;

                            HorizontalLayout {
                                height: 34px;
                                spacing: 12px;

                                Txt {
                                    text: I18n.tr("联机节点", "Network Peers", "ネットワークノード");
                                    color: #eef4fb;
                                    font-size: 18px;
                                    font-weight: 800;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }

                                Txt {
                                    text: vnt_peer_summary_text;
                                    color: #95a3b8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                            }

                            ListView {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;

                                for peer in vnt_peer_rows: VntPeerLine {
                                    name: peer.name;
                                    address: peer.address;
                                    detail: peer.detail;
                                    online: peer.online;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if page_locked : Rectangle {
        width: parent.width;
        height: parent.height;
        background: #0b0e13b8;

        Rectangle {
            width: min(parent.width - 96px, 560px);
            height: 170px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 28px;
            border-width: 1px;
            border-color: #62e2c155;
            background: #101721aa;

            Txt {
                width: parent.width;
                height: parent.height;
                text: I18n.tr("暂未开放", "Not Available Yet", "未公開");
                color: #eef4fbc8;
                font-size: 54px;
                font-weight: 900;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        blocker := TouchArea {
            width: parent.width;
            height: parent.height;
        }
    }
}
