import { ListView, ScrollView } from "std-widgets.slint";
import { VntPeerRow, VntServerRow } from "../models.slint";
import { Action, InfoBox, OptionSwitch, Panel, ServerDropdown, TextField, TitleBlock, Txt } from "../components.slint";
import { VntPeerLine, VntServerLine } from "../rows.slint";

export component VntPage inherits Rectangle {
    private property <bool> page_locked: true;
    in-out property <string> vnt_server_text;
    in-out property <string> vnt_new_server_text;
    in property <[string]> vnt_server_options;
    in-out property <string> vnt_network_code;
    in-out property <string> vnt_password;
    in-out property <bool> vnt_no_tun;
    in-out property <bool> vnt_compress;
    in-out property <bool> vnt_rtx;
    in property <bool> vnt_busy;
    in property <bool> vnt_running;
    in property <string> vnt_status_text;
    in property <string> vnt_detail_text;
    in property <string> vnt_ip_text;
    in property <string> vnt_server_status_text;
    in property <string> vnt_nat_text;
    in property <string> vnt_peer_summary_text;
    in property <[VntServerRow]> vnt_server_rows;
    in property <[VntPeerRow]> vnt_peer_rows;
    callback vnt_start_clicked();
    callback vnt_stop_clicked();
    callback vnt_refresh_clicked();
    callback vnt_add_server_clicked(address: string);
    callback vnt_settings_changed();

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        spacing: 16px;

        Panel {
            width: 420px;
            vertical-stretch: 1;
            radius: 26px;

            VerticalLayout {
                padding: 22px;
                spacing: 12px;

                TitleBlock {
                    title: "联机";
                    sub: vnt_running ? "虚拟局域网已运行" : "创建或加入同一个网络编号";
                }

                InfoBox {
                    box-height: 78px;
                    label: "STATUS";
                    value: vnt_status_text + "\n" + vnt_detail_text;
                    accent: vnt_running ? #9ef0b5 : (vnt_busy ? #f6c76d : #a8d8ff);
                }

                ScrollView {
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    viewport-height: form.height;

                    form := Rectangle {
                        width: parent.width - 14px;
                        height: 390px;
                        background: #00000000;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            spacing: 8px;

                            Txt {
                                text: "服务器地址";
                                color: #95a3b8;
                                font-size: 12px;
                                font-weight: 700;
                            }

                            ServerDropdown {
                                value <=> root.vnt_server_text;
                                options: root.vnt_server_options;
                                enabled: !vnt_running && !vnt_busy;
                                selected(value) => {
                                    root.vnt_server_text = value;
                                    root.vnt_settings_changed();
                                }
                            }

                            HorizontalLayout {
                                height: 46px;
                                spacing: 10px;

                                TextField {
                                    horizontal-stretch: 1;
                                    text <=> root.vnt_new_server_text;
                                    placeholder: "输入自定义服务器地址";
                                    enabled: !vnt_running && !vnt_busy;
                                    accepted => {
                                        if root.vnt_new_server_text != "" {
                                            root.vnt_add_server_clicked(root.vnt_new_server_text);
                                        }
                                    }
                                }

                                Action {
                                    width: 86px;
                                    height: 46px;
                                    label: "添加";
                                    sub: "";
                                    enabled: !vnt_running && !vnt_busy && vnt_new_server_text != "";
                                    accent: #62e2c1;
                                    clicked => {
                                        if root.vnt_new_server_text != "" {
                                            root.vnt_add_server_clicked(root.vnt_new_server_text);
                                        }
                                    }
                                }
                            }

                            Txt {
                                text: "网络编号";
                                color: #95a3b8;
                                font-size: 12px;
                                font-weight: 700;
                            }

                            TextField {
                                text <=> root.vnt_network_code;
                                placeholder: "相同编号会进入同一虚拟局域网";
                                enabled: !vnt_running && !vnt_busy;
                                edited(text) => {
                                    root.vnt_network_code = text;
                                    root.vnt_settings_changed();
                                }
                            }

                            Txt {
                                text: "加密密码";
                                color: #95a3b8;
                                font-size: 12px;
                                font-weight: 700;
                            }

                            TextField {
                                text <=> root.vnt_password;
                                placeholder: "可选";
                                enabled: !vnt_running && !vnt_busy;
                                input-type: InputType.password;
                                edited(text) => {
                                    root.vnt_password = text;
                                    root.vnt_settings_changed();
                                }
                            }

                            VerticalLayout {
                                height: 104px;
                                spacing: 8px;

                                OptionSwitch {
                                    enabled: !vnt_running && !vnt_busy;
                                    checked: vnt_no_tun;
                                    on-label: "端口模式";
                                    off-label: "虚拟网卡模式";
                                    sub: vnt_no_tun ? "不创建虚拟网卡" : "游戏局域网联机";
                                    toggled(value) => {
                                        root.vnt_no_tun = value;
                                        root.vnt_settings_changed();
                                    }
                                }

                                HorizontalLayout {
                                    height: 48px;
                                    spacing: 8px;

                                    OptionSwitch {
                                        horizontal-stretch: 1;
                                        enabled: !vnt_running && !vnt_busy;
                                        checked: vnt_compress;
                                        on-label: "压缩传输";
                                        off-label: "压缩传输";
                                        sub: vnt_compress ? "已开启" : "弱网可开启";
                                        toggled(value) => {
                                            root.vnt_compress = value;
                                            root.vnt_settings_changed();
                                        }
                                    }

                                    OptionSwitch {
                                        horizontal-stretch: 1;
                                        enabled: !vnt_running && !vnt_busy;
                                        checked: vnt_rtx;
                                        on-label: "QUIC 通道";
                                        off-label: "QUIC 通道";
                                        sub: vnt_rtx ? "已开启" : "高丢包可开";
                                        toggled(value) => {
                                            root.vnt_rtx = value;
                                            root.vnt_settings_changed();
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    height: 58px;
                    spacing: 12px;

                    Action {
                        horizontal-stretch: 1;
                        label: vnt_running ? "运行中" : (vnt_busy ? "启动中" : "启动联机");
                        sub: vnt_running ? "网络已建立" : "START";
                        enabled: !vnt_running && !vnt_busy;
                        primary: false;
                        accent: #62e2c1;
                        clicked => { root.vnt_start_clicked(); }
                    }

                    Action {
                        width: 128px;
                        label: vnt_busy ? "处理中" : "停止";
                        sub: "";
                        enabled: vnt_running && !vnt_busy;
                        accent: #ffb4ab;
                        clicked => { root.vnt_stop_clicked(); }
                    }
                }
            }
        }

        Panel {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            radius: 26px;

            VerticalLayout {
                padding: 24px;
                spacing: 14px;

                HorizontalLayout {
                    height: 50px;
                    spacing: 12px;

                    TitleBlock {
                        horizontal-stretch: 1;
                        title: "联机状态";
                        sub: vnt_peer_summary_text;
                    }

                    Action {
                        width: 132px;
                        label: "刷新";
                        sub: "";
                        enabled: vnt_running && !vnt_busy;
                        accent: #a8d8ff;
                        clicked => { root.vnt_refresh_clicked(); }
                    }
                }

                HorizontalLayout {
                    height: 76px;
                    spacing: 12px;

                    InfoBox {
                        horizontal-stretch: 1;
                        box-height: 76px;
                        label: "VIRTUAL IP";
                        value: vnt_ip_text;
                        accent: vnt_running ? #9ef0b5 : #54617a;
                    }

                    InfoBox {
                        horizontal-stretch: 1;
                        box-height: 76px;
                        label: "SERVER";
                        value: vnt_server_status_text;
                        accent: vnt_running ? #a8d8ff : #54617a;
                    }
                }

                HorizontalLayout {
                    height: 76px;
                    spacing: 12px;

                    InfoBox {
                        horizontal-stretch: 1;
                        box-height: 76px;
                        label: "NETWORK";
                        value: vnt_network_code == "" ? "-" : vnt_network_code;
                        accent: #d7c4ff;
                    }

                    InfoBox {
                        horizontal-stretch: 1;
                        box-height: 76px;
                        label: "NAT";
                        value: vnt_nat_text;
                        accent: #f6c76d;
                    }
                }

                VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 12px;

                    Panel {
                        height: 190px;
                        fill: #0f131a;
                        radius: 18px;

                        VerticalLayout {
                            padding: 14px;
                            spacing: 8px;

                            HorizontalLayout {
                                height: 34px;
                                spacing: 12px;

                                Txt {
                                    text: "VNT 服务器";
                                    color: #eef4fb;
                                    font-size: 18px;
                                    font-weight: 800;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }

                                Txt {
                                    text: vnt_server_status_text;
                                    color: #95a3b8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                            }

                            ListView {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;

                                for server in vnt_server_rows: VntServerLine {
                                    name: server.name;
                                    address: server.address;
                                    detail: server.detail;
                                    online: server.online;
                                }
                            }
                        }
                    }

                    Panel {
                        vertical-stretch: 1;
                        fill: #0f131a;
                        radius: 18px;

                        VerticalLayout {
                            padding: 14px;
                            spacing: 8px;

                            HorizontalLayout {
                                height: 34px;
                                spacing: 12px;

                                Txt {
                                    text: "联机节点";
                                    color: #eef4fb;
                                    font-size: 18px;
                                    font-weight: 800;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }

                                Txt {
                                    text: vnt_peer_summary_text;
                                    color: #95a3b8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                            }

                            ListView {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;

                                for peer in vnt_peer_rows: VntPeerLine {
                                    name: peer.name;
                                    address: peer.address;
                                    detail: peer.detail;
                                    online: peer.online;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if page_locked : Rectangle {
        width: parent.width;
        height: parent.height;
        background: #0b0e13b8;

        Rectangle {
            width: min(parent.width - 96px, 560px);
            height: 170px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 28px;
            border-width: 1px;
            border-color: #62e2c155;
            background: #101721aa;

            Txt {
                width: parent.width;
                height: parent.height;
                text: "暂未开放";
                color: #eef4fbc8;
                font-size: 54px;
                font-weight: 900;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        blocker := TouchArea {
            width: parent.width;
            height: parent.height;
        }
    }
}
