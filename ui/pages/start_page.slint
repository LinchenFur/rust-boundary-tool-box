import { LineEdit, ListView, ScrollView } from "std-widgets.slint";
import { PortRow, ServerRow, VntPeerRow } from "../models.slint";
import { Action, DetailRow, InfoBox, InputBox, NavTab, OptionSwitch, Panel, TitleBlock, Txt } from "../components.slint";
import { PortLine, ServerLine, VntPeerLine } from "../rows.slint";
import { I18n } from "../i18n.slint";

export component StartPage inherits Rectangle {
    in property <bool> has_target;
    in property <bool> busy;
    in property <bool> is_admin: true;
    in property <bool> auto_mode;
    in property <string> status_text;
    in property <string> target_text;
    in property <string> detected_text;
    callback launch_pvp_clicked();
    callback launch_pve_clicked();
    callback install_clicked();
    callback uninstall_clicked();
    callback scan_clicked();
    callback goto_directory();
        // 页面 0：启动和快捷安装/卸载操作。
        HorizontalLayout {
            width: parent.width;
            height: parent.height;
            spacing: 16px;

            Panel {
                width: 470px;
                vertical-stretch: 1;
                radius: 26px;
                fill: #172032;
                stroke: #344056;

                VerticalLayout {
                    padding: 28px;
                    spacing: 20px;

                    TitleBlock {
                        title: I18n.tr("启动模式", "Launch Mode", "起動モード");
                        sub: has_target
                            ? I18n.tr("选择 PVP 或 PVE 启动流程", "Choose the PVP or PVE launch flow", "PVP または PVE の起動フローを選択")
                            : I18n.tr("先完成目录识别后再启动", "Resolve the game path before launching", "起動前にゲームパスを設定してください");
                    }

                    Action {
                        label: I18n.tr("启动 PVE", "Launch PVE", "PVE を起動");
                        sub: "";
                        primary: true;
                        enabled: has_target && !busy;
                        accent: #62e2c1;
                        clicked => { root.launch_pve_clicked(); }
                    }

                    Action {
                        label: I18n.tr("启动 PVP", "Launch PVP", "PVP を起動");
                        sub: "";
                        enabled: has_target && !busy;
                        accent: #a8d8ff;
                        clicked => { root.launch_pvp_clicked(); }
                    }

                    HorizontalLayout {
                        spacing: 12px;

                        Action {
                            horizontal-stretch: 1;
                            label: I18n.tr("安装", "Install", "インストール");
                            sub: I18n.tr("写入社区服文件", "Write community server files", "コミュニティサーバーファイルを書き込み");
                            enabled: has_target && !busy && is_admin;
                            accent: #9ef0b5;
                            clicked => { root.install_clicked(); }
                        }

                        Action {
                            horizontal-stretch: 1;
                            label: I18n.tr("卸载", "Uninstall", "アンインストール");
                            sub: I18n.tr("移除已安装文件", "Remove installed files", "インストール済みファイルを削除");
                            enabled: has_target && !busy && is_admin;
                            accent: #ffb4ab;
                            clicked => { root.uninstall_clicked(); }
                        }
                    }

                    InfoBox {
                        box-height: 96px;
                        label: I18n.tr("任务", "TASK", "タスク");
                        value: status_text;
                        accent: busy ? #ffb4ab : #9ef0b5;
                    }
                }
            }

            Panel {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                radius: 26px;

                VerticalLayout {
                    padding: 28px;
                    spacing: 16px;

                    TitleBlock {
                        title: I18n.tr("当前目标", "Current Target", "現在の対象");
                        sub: auto_mode
                            ? I18n.tr("自动识别", "Auto detect", "自動検出")
                            : I18n.tr("手动选择", "Manual selection", "手動選択");
                    }

                    InfoBox {
                        box-height: 132px;
                        label: I18n.tr("目标", "TARGET", "対象");
                        value: target_text;
                        accent: has_target ? #9ef0b5 : #f6c76d;
                    }

                    InfoBox {
                        box-height: 132px;
                        label: I18n.tr("检测结果", "DETECTED", "検出結果");
                        value: detected_text;
                        accent: #a8d8ff;
                    }

                    HorizontalLayout {
                        spacing: 12px;

                        Action {
                            horizontal-stretch: 1;
                            label: I18n.tr("去目录页", "Open Path Page", "パス画面へ");
                            sub: I18n.tr("修改或重新识别目录", "Edit or re-detect the game path", "パスを変更または再検出");
                            accent: #a8d8ff;
                            clicked => { root.goto_directory(); }
                        }

                        Action {
                            horizontal-stretch: 1;
                            label: I18n.tr("全盘扫描", "Full Scan", "全体スキャン");
                            sub: I18n.tr("查找游戏目录", "Find the game path", "ゲームパスを検索");
                            enabled: !busy;
                            accent: #9ef0b5;
                            clicked => { root.scan_clicked(); }
                        }
                    }
                }
            }
        }
}

