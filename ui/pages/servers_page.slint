import { LineEdit, ListView, ScrollView } from "std-widgets.slint";
import { PortRow, ServerRow, VntPeerRow } from "../models.slint";
import { Action, DetailRow, InfoBox, InputBox, NavTab, OptionSwitch, Panel, TitleBlock, Txt } from "../components.slint";
import { PortLine, ServerLine, VntPeerLine } from "../rows.slint";
import { I18n } from "../i18n.slint";

export component ServersPage inherits Rectangle {
    in property <bool> servers_loading;
    in property <string> server_status_text;
    in property <[ServerRow]> server_rows;
    callback refresh_servers_clicked();
        // 页面 4：来自 JSON 接口的远程社区服列表。
        HorizontalLayout {
            width: parent.width;
            height: parent.height;
            spacing: 16px;

            Panel {
                width: 360px;
                vertical-stretch: 1;
                radius: 26px;

                VerticalLayout {
                    padding: 24px;
                    spacing: 16px;

                    TitleBlock {
                        title: I18n.tr("服务器", "Servers", "サーバー");
                    }

                    InfoBox {
                        box-height: 108px;
                        label: I18n.tr("状态", "STATUS", "状態");
                        value: server_status_text;
                        accent: servers_loading ? #f6c76d : #9ef0b5;
                    }

                    Action {
                        label: servers_loading
                            ? I18n.tr("刷新中", "Refreshing", "更新中")
                            : I18n.tr("刷新服务器", "Refresh Servers", "サーバーを更新");
                        sub: I18n.tr("读取最新 JSON", "Load latest JSON", "最新 JSON を読み込み");
                        enabled: !servers_loading;
                        accent: #d7c4ff;
                        clicked => { root.refresh_servers_clicked(); }
                    }
                }
            }

            Panel {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                radius: 26px;

                VerticalLayout {
                    padding: 24px;
                    spacing: 14px;

                    TitleBlock {
                        title: I18n.tr("服务器列表", "Server List", "サーバー一覧");
                        sub: server_status_text;
                    }

                    ListView {
                        vertical-stretch: 1;

                        for server in server_rows: ServerLine {
                            name: server.name;
                            address: server.address;
                            meta: server.meta;
                            state: server.state;
                            players: server.players;
                            active: server.active;
                        }
                    }
                }
            }
        }
}
