import { LineEdit, ListView, ScrollView } from "std-widgets.slint";
import { PortRow, ServerRow, VntPeerRow } from "../models.slint";
import { Action, DetailRow, InfoBox, InputBox, NavTab, OptionSwitch, Panel, TitleBlock, Txt } from "../components.slint";
import { PortLine, ServerLine, VntPeerLine } from "../rows.slint";
import { I18n } from "../i18n.slint";

export component DiagnosticsPage inherits Rectangle {
    in property <bool> has_target;
    in property <bool> busy;
    in property <bool> show_logs;
    in property <string> process_status_text;
    in property <string> system_status_text;
    in property <bool> system_status_warning;
    in property <string> log_text;
    in property <[PortRow]> port_rows;
    callback detect_processes_clicked();
    callback stop_processes_clicked();
    callback stop_port_process_clicked(protocol: string, port: int, pid: int);
    callback toggle_logs_clicked();
        // 页面 2：进程/端口诊断和会话日志。
        HorizontalLayout {
            width: parent.width;
            height: parent.height;
            spacing: 16px;

            Panel {
                width: 360px;
                vertical-stretch: 1;
                radius: 26px;

                VerticalLayout {
                    padding: 24px;
                    spacing: 16px;

                    TitleBlock {
                        title: I18n.tr("进程", "Processes", "プロセス");
                        sub: I18n.tr("检测或关闭可能占用端口的进程", "Detect or stop processes that may occupy ports", "ポートを占有する可能性のあるプロセスを確認または停止");
                    }

                    InfoBox {
                        box-height: 120px;
                        label: I18n.tr("进程", "PROCESS", "プロセス");
                        value: process_status_text;
                        accent: #d7c4ff;
                    }

                    InfoBox {
                        box-height: 166px;
                        label: I18n.tr("系统", "SYSTEM", "システム");
                        value: system_status_text;
                        accent: system_status_warning ? #ffb4ab : #9ef0b5;
                    }

                    Action {
                        label: I18n.tr("进程检测", "Detect Processes", "プロセス検出");
                        sub: I18n.tr("扫描运行进程", "Scan running processes", "実行中プロセスをスキャン");
                        enabled: has_target && !busy;
                        accent: #d7c4ff;
                        clicked => { root.detect_processes_clicked(); }
                    }

                    Action {
                        label: I18n.tr("关闭相关进程", "Stop Related Processes", "関連プロセスを停止");
                        sub: I18n.tr("结束游戏/登录服/包装器", "Stop game/login server/wrapper", "ゲーム/ログインサーバー/ラッパーを終了");
                        enabled: has_target && !busy;
                        accent: #ffb4ab;
                        clicked => { root.stop_processes_clicked(); }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                        background: #00000000;
                    }
                }
            }

            Panel {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                radius: 26px;

                VerticalLayout {
                    padding: 18px;
                    spacing: 8px;

                    HorizontalLayout {
                        height: 54px;
                        spacing: 12px;

                        TitleBlock {
                            horizontal-stretch: 1;
                            title: show_logs ? I18n.tr("日志", "Logs", "ログ") : I18n.tr("端口", "Ports", "ポート");
                            sub: show_logs
                                ? I18n.tr("运行日志输出", "Runtime log output", "実行ログ出力")
                                : I18n.tr("社区服端口占用状态", "Community server port occupancy", "コミュニティサーバーポートの占有状態");
                        }

                        Action {
                            width: 140px;
                            label: show_logs ? I18n.tr("看端口", "Show Ports", "ポート表示") : I18n.tr("看日志", "Show Logs", "ログ表示");
                            sub: "";
                            enabled: !busy;
                            accent: #d7c4ff;
                            clicked => { root.toggle_logs_clicked(); }
                        }
                    }

                    if !show_logs : ListView {
                        vertical-stretch: 1;

                        for port_row[index] in port_rows: PortLine {
                            label: port_row.label;
                            detail: port_row.detail;
                            pid: port_row.pid;
                            busy: root.busy;
                            occupied: port_row.occupied;
                            expected: port_row.expected;
                            close_clicked => {
                                root.stop_port_process_clicked(port_row.protocol, port_row.port, port_row.pid);
                            }
                        }
                    }

                    if show_logs : ScrollView {
                        vertical-stretch: 1;

                        Txt {
                            x: 14px;
                            y: 14px;
                            width: parent.width - 28px;
                            text: log_text;
                            color: #dbeafe;
                            font-family: "Maple Mono CN";
                            font-size: 13px;
                            font-weight: 500;
                            wrap: char-wrap;
                        }
                    }
                }
            }
        }
}
