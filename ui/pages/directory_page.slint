import { LineEdit, ListView, ScrollView } from "std-widgets.slint";
import { PortRow, ServerRow, VntPeerRow } from "../models.slint";
import { Action, DetailRow, InfoBox, InputBox, NavTab, OptionSwitch, Panel, TitleBlock, Txt } from "../components.slint";
import { PortLine, ServerLine, VntPeerLine } from "../rows.slint";
import { I18n } from "../i18n.slint";

export component DirectoryPage inherits Rectangle {
    in property <bool> has_target;
    in property <bool> busy;
    in property <bool> auto_mode;
    in property <string> manual_path;
    in property <string> detected_text;
    in property <string> target_text;
    callback auto_mode_clicked();
    callback manual_mode_clicked();
    callback scan_clicked();
    callback redetect_clicked();
    callback browse_clicked();
    callback manual_path_changed(text: string);
        // 页面 1：Steam 自动识别、手动路径输入和盘符扫描。
        HorizontalLayout {
            width: parent.width;
            height: parent.height;
            spacing: 16px;

            Panel {
                width: 360px;
                vertical-stretch: 1;
                radius: 26px;

                VerticalLayout {
                    padding: 24px;
                    spacing: 16px;

                    TitleBlock {
                        title: I18n.tr("识别方式", "Path Mode", "パス指定方式");
                        sub: I18n.tr("选择自动识别或手动指定目录", "Use auto detection or choose a path manually", "自動検出または手動指定を選択");
                    }

                    NavTab {
                        label: I18n.tr("自动识别", "Auto Detect", "自動検出");
                        selected: auto_mode;
                        clicked => { root.auto_mode_clicked(); }
                    }

                    NavTab {
                        label: I18n.tr("手动选择", "Manual", "手動選択");
                        selected: !auto_mode;
                        clicked => { root.manual_mode_clicked(); }
                    }

                    Action {
                        label: I18n.tr("全盘扫描", "Full Scan", "全体スキャン");
                        sub: I18n.tr("选择盘符后扫描", "Select drives before scanning", "ドライブを選択してスキャン");
                        enabled: !busy;
                        accent: #9ef0b5;
                        clicked => { root.scan_clicked(); }
                    }

                    Action {
                        label: I18n.tr("重新检测", "Re-detect", "再検出");
                        sub: I18n.tr("刷新自动识别结果", "Refresh auto detection", "自動検出結果を更新");
                        enabled: auto_mode && !busy;
                        accent: #a8d8ff;
                        clicked => { root.redetect_clicked(); }
                    }
                }
            }

            Panel {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                radius: 26px;

                VerticalLayout {
                    padding: 24px;
                    spacing: 16px;

                    TitleBlock {
                        title: I18n.tr("游戏根目录", "Game Root", "ゲームルート");
                        sub: I18n.tr("手动模式下可直接输入或浏览目录", "Enter or browse a path in manual mode", "手動モードで入力または参照できます");
                    }

                    InputBox {
                        enabled: !auto_mode && !busy;

                        LineEdit {
                            x: 14px;
                            y: 8px;
                            width: parent.width - 28px;
                            height: parent.height - 16px;
                            text: manual_path;
                            enabled: !auto_mode && !busy;
                            placeholder-text: I18n.tr("游戏根目录", "Game root", "ゲームルート");
                            font-family: "Maple Mono NF CN";
                            font-size: 14px;
                            edited(text) => { root.manual_path_changed(text); }
                        }
                    }

                    HorizontalLayout {
                        height: 54px;
                        spacing: 12px;

                        Action {
                            width: 150px;
                            label: I18n.tr("浏览", "Browse", "参照");
                            sub: I18n.tr("打开", "OPEN", "開く");
                            enabled: !auto_mode && !busy;
                            accent: #62e2c1;
                            clicked => { root.browse_clicked(); }
                        }

                        Rectangle { horizontal-stretch: 1; background: #00000000; }
                    }

                    InfoBox {
                        box-height: 128px;
                        label: I18n.tr("检测结果", "DETECTED", "検出結果");
                        value: detected_text;
                        accent: #a8d8ff;
                    }

                    InfoBox {
                        box-height: 120px;
                        label: I18n.tr("目标", "TARGET", "対象");
                        value: target_text;
                        accent: has_target ? #9ef0b5 : #f6c76d;
                    }
                }
            }
        }
}

