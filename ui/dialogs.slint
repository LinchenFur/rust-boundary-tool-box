import { LineEdit, ListView, ScrollView } from "std-widgets.slint";
import { DriveRow } from "models.slint";
import { Action, InputBox, Panel, ProgressBox, TitleBlock, Txt } from "components.slint";
import { DriveLine } from "rows.slint";
import { I18n } from "i18n.slint";

export component DriveScanDialog inherits Rectangle {
    in property <bool> busy;
    in property <[DriveRow]> drive_rows;
    callback drive_toggled(index: int, checked: bool);
    callback drive_confirmed();
    callback drive_cancelled();
    Rectangle {
        width: parent.width;
        height: parent.height;
        background: #05070bcc;

        Panel {
            width: 560px;
            height: 520px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            radius: 24px;

            VerticalLayout {
                padding: 22px;
                spacing: 14px;

                TitleBlock {
                    title: I18n.tr("选择扫描盘符", "Select Drives to Scan", "スキャンするドライブを選択");
                    sub: I18n.tr("只扫描勾选的磁盘", "Only selected drives will be scanned", "選択したドライブのみスキャンします");
                }

                Panel {
                    vertical-stretch: 1;
                    fill: #0f131a;
                    radius: 18px;

                    ListView {
                        x: 12px;
                        y: 10px;
                        width: parent.width - 24px;
                        height: parent.height - 20px;

                        for drive[index] in drive_rows: DriveLine {
                            label: drive.label;
                            checked: drive.checked;
                            toggled => { root.drive_toggled(index, !drive.checked); }
                        }
                    }
                }

                HorizontalLayout {
                    height: 58px;
                    spacing: 12px;

                    Rectangle { horizontal-stretch: 1; background: #00000000; }

                    Action {
                        width: 132px;
                        label: I18n.tr("取消", "Cancel", "キャンセル");
                        sub: "";
                        enabled: !busy;
                        accent: #ffb4ab;
                        clicked => { root.drive_cancelled(); }
                    }

                    Action {
                        width: 156px;
                        label: I18n.tr("开始扫描", "Start Scan", "スキャン開始");
                        sub: "";
                        enabled: !busy;
                        accent: #62e2c1;
                        clicked => { root.drive_confirmed(); }
                    }
                }
            }
        }
    }
}

export component AppDialog inherits Rectangle {
    in property <bool> app_dialog_confirm;
    in property <bool> app_dialog_input;
    in property <bool> app_dialog_error;
    in property <string> app_dialog_title;
    in property <string> app_dialog_text;
    in-out property <string> app_dialog_input_text;
    in property <string> app_dialog_primary_text;
    in property <string> app_dialog_secondary_text;
    callback app_dialog_primary();
    callback app_dialog_secondary();
    Rectangle {
        width: parent.width;
        height: parent.height;
        background: #05070bd9;

        Panel {
            width: 560px;
            height: app_dialog_input ? 360px : (app_dialog_confirm ? 318px : 292px);
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            radius: 24px;

            VerticalLayout {
                padding: 24px;
                spacing: 14px;

                HorizontalLayout {
                    height: 52px;
                    spacing: 12px;

                    Rectangle {
                        width: 8px;
                        background: #00000000;

                        Rectangle {
                            width: 8px;
                            height: 40px;
                            y: (parent.height - self.height) / 2;
                            border-radius: 4px;
                            background: app_dialog_error ? #ffb4ab : (app_dialog_confirm ? #f6c76d : #9ef0b5);
                        }
                    }

                    TitleBlock {
                        horizontal-stretch: 1;
                        title: app_dialog_title;
                        sub: app_dialog_confirm ? I18n.tr("需要确认", "Confirmation Required", "確認が必要です") : "";
                    }
                }

                ScrollView {
                    vertical-stretch: 1;

                    Txt {
                        x: 0px;
                        y: 0px;
                        width: parent.width;
                        text: app_dialog_text;
                        color: #dbeafe;
                        font-size: 14px;
                        font-weight: 500;
                        wrap: char-wrap;
                    }
                }

                if app_dialog_input : InputBox {
                    enabled: true;

                    LineEdit {
                        x: 14px;
                        y: 8px;
                        width: parent.width - 28px;
                        height: parent.height - 16px;
                        text: app_dialog_input_text;
                        placeholder-text: I18n.tr("游戏根目录", "Game root", "ゲームルート");
                        font-family: "Maple Mono NF CN";
                        font-size: 14px;
                        edited(text) => { root.app_dialog_input_text = text; }
                    }
                }

                HorizontalLayout {
                    height: 58px;
                    spacing: 12px;

                    Rectangle { horizontal-stretch: 1; background: #00000000; }

                    if app_dialog_confirm || app_dialog_input : Action {
                        width: 132px;
                        label: app_dialog_secondary_text;
                        sub: "";
                        accent: #ffb4ab;
                        clicked => { root.app_dialog_secondary(); }
                    }

                    Action {
                        width: 156px;
                        label: app_dialog_primary_text;
                        sub: "";
                        accent: app_dialog_error ? #ffb4ab : #62e2c1;
                        clicked => { root.app_dialog_primary(); }
                    }
                }
            }
        }
    }
}

export component InstallProgressDialog inherits Rectangle {
    in property <bool> busy;
    in property <float> progress: 0.0;
    in property <string> percent: "0%";
    in property <string> title: "";
    in property <string> detail: "";
    callback close_clicked();

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: #05070bd9;

        Panel {
            width: 560px;
            height: 280px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            radius: 24px;

            VerticalLayout {
                padding: 24px;
                spacing: 14px;

                TitleBlock {
                    title: I18n.tr("安装进度", "Install Progress", "インストール進捗");
                    sub: "";
                }

                ProgressBox {
                    shown: true;
                    progress: root.progress;
                    percent: root.percent;
                    title: root.title;
                    detail: root.detail;
                }

                HorizontalLayout {
                    height: 58px;
                    spacing: 12px;

                    Rectangle { horizontal-stretch: 1; background: #00000000; }

                    Action {
                        width: 156px;
                        label: busy ? I18n.tr("安装中", "Installing", "インストール中") : I18n.tr("完成", "Done", "完了");
                        sub: "";
                        enabled: !busy;
                        accent: #62e2c1;
                        clicked => { root.close_clicked(); }
                    }
                }
            }
        }
    }
}
