import { LineEdit, ListView, ScrollView } from "std-widgets.slint";
import { DriveRow, ProxyRow } from "models.slint";
import { Action, InputBox, Panel, ProgressBox, TitleBlock, Txt } from "components.slint";
import { DriveLine, ProxyLine } from "rows.slint";
import { I18n } from "i18n.slint";

export component DriveScanDialog inherits Rectangle {
    in property <bool> busy;
    in property <[DriveRow]> drive_rows;
    callback drive_toggled(index: int, checked: bool);
    callback drive_confirmed();
    callback drive_cancelled();
    Rectangle {
        width: parent.width;
        height: parent.height;
        background: #05070bcc;

        dialog := Panel {
            property <length> max-panel-width: root.width > 64px ? root.width - 64px : root.width;
            property <length> max-panel-height: root.height > 64px ? root.height - 64px : root.height;
            property <length> fixed-height: 182px;
            property <length> natural-list-height: drive_rows.length <= 0 ? 64px : 20px + 58px * drive_rows.length;
            property <length> available-list-height: max-panel-height > fixed-height + 64px ? max-panel-height - fixed-height : 64px;
            property <length> list-height: min(natural-list-height, available-list-height);

            width: min(560px, max-panel-width);
            height: min(max-panel-height, fixed-height + list-height);
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            radius: 24px;

            VerticalLayout {
                padding: 22px;
                spacing: 14px;

                TitleBlock {
                    title: I18n.tr("选择扫描盘符", "Select Drives to Scan", "スキャンするドライブを選択");
                    sub: I18n.tr("只扫描勾选的磁盘", "Only selected drives will be scanned", "選択したドライブのみスキャンします");
                }

                Panel {
                    height: dialog.list-height;
                    fill: #0f131a;
                    radius: 18px;

                    ListView {
                        x: 12px;
                        y: 10px;
                        width: parent.width - 24px;
                        height: parent.height - 20px;

                        for drive[index] in drive_rows: DriveLine {
                            label: drive.label;
                            checked: drive.checked;
                            toggled => { root.drive_toggled(index, !drive.checked); }
                        }
                    }
                }

                HorizontalLayout {
                    height: 58px;
                    spacing: 12px;

                    Rectangle { horizontal-stretch: 1; background: #00000000; }

                    Action {
                        width: 132px;
                        label: I18n.tr("取消", "Cancel", "キャンセル");
                        sub: "";
                        enabled: !busy;
                        accent: #ffb4ab;
                        clicked => { root.drive_cancelled(); }
                    }

                    Action {
                        width: 156px;
                        label: I18n.tr("开始扫描", "Start Scan", "スキャン開始");
                        sub: "";
                        enabled: !busy;
                        accent: #62e2c1;
                        clicked => { root.drive_confirmed(); }
                    }
                }
            }
        }
    }
}

export component ProxySelectDialog inherits Rectangle {
    in property <bool> busy;
    in property <bool> loading;
    in property <string> status_text;
    in property <[ProxyRow]> proxy_rows;
    callback proxy_selected(url: string);
    callback proxy_refresh_clicked();
    callback proxy_cancelled();

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: #05070bd9;

        dialog := Panel {
            property <length> max-panel-width: root.width > 64px ? root.width - 64px : root.width;
            property <length> max-panel-height: root.height > 64px ? root.height - 64px : root.height;
            property <length> fixed-height: 178px;
            property <length> natural-list-height: proxy_rows.length <= 0 ? 72px : 18px + 68px * proxy_rows.length;
            property <length> available-list-height: max-panel-height > fixed-height + 64px ? max-panel-height - fixed-height : 64px;
            property <length> list-height: min(natural-list-height, available-list-height);

            width: min(760px, max-panel-width);
            height: min(max-panel-height, fixed-height + list-height);
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            radius: 24px;

            VerticalLayout {
                padding: 24px;
                spacing: 14px;

                TitleBlock {
                    title: I18n.tr("选择下载代理", "Select Download Proxy", "ダウンロードプロキシを選択");
                    sub: status_text;
                }

                Panel {
                    height: dialog.list-height;
                    fill: #0f131a;
                    radius: 18px;

                    if proxy_rows.length <= 0 : Txt {
                        x: 18px;
                        y: 0px;
                        width: parent.width - 36px;
                        height: parent.height;
                        text: loading
                            ? I18n.tr("正在获取代理列表...", "Loading proxy list...", "プロキシ一覧を読み込み中...")
                            : I18n.tr("暂无代理节点", "No proxy nodes", "プロキシノードがありません");
                        color: #95a3b8;
                        font-size: 13px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }

                    if proxy_rows.length > 0 : ListView {
                        x: 12px;
                        y: 10px;
                        width: parent.width - 24px;
                        height: parent.height - 20px;

                        for proxy[index] in proxy_rows: ProxyLine {
                            url: proxy.url;
                            latency: proxy.latency;
                            state: proxy.state;
                            current: proxy.current;
                            selected => { root.proxy_selected(proxy.url); }
                        }
                    }
                }

                HorizontalLayout {
                    height: 58px;
                    spacing: 12px;

                    Action {
                        width: 132px;
                        label: loading ? I18n.tr("测速中", "Testing", "測定中") : I18n.tr("刷新延迟", "Refresh Ping", "遅延を更新");
                        sub: "";
                        enabled: !busy && !loading;
                        accent: #a8d8ff;
                        clicked => { root.proxy_refresh_clicked(); }
                    }

                    Rectangle { horizontal-stretch: 1; background: #00000000; }

                    Action {
                        width: 132px;
                        label: I18n.tr("取消", "Cancel", "キャンセル");
                        sub: "";
                        enabled: !busy;
                        accent: #ffb4ab;
                        clicked => { root.proxy_cancelled(); }
                    }
                }
            }
        }
    }
}

export component AppDialog inherits Rectangle {
    in property <bool> app_dialog_confirm;
    in property <bool> app_dialog_input;
    in property <bool> app_dialog_error;
    in property <int> app_dialog_text_lines: 1;
    in property <string> app_dialog_title;
    in property <string> app_dialog_text;
    in-out property <string> app_dialog_input_text;
    in property <string> app_dialog_primary_text;
    in property <string> app_dialog_secondary_text;
    callback app_dialog_primary();
    callback app_dialog_secondary();
    Rectangle {
        width: parent.width;
        height: parent.height;
        background: #05070bd9;

        dialog := Panel {
            property <length> max-panel-width: root.width > 64px ? root.width - 64px : root.width;
            property <length> max-panel-height: root.height > 64px ? root.height - 64px : root.height;
            property <length> fixed-height: app_dialog_input ? 246px : 186px;
            property <length> natural-text-height: app_dialog_text_lines <= 1 ? 34px : app_dialog_text_lines * 22px;
            property <length> available-text-height: max-panel-height > fixed-height + 56px ? max-panel-height - fixed-height : 56px;
            property <length> text-height: min(natural-text-height, available-text-height);

            width: min(680px, max-panel-width);
            height: min(max-panel-height, fixed-height + text-height);
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            radius: 24px;

            VerticalLayout {
                padding: 24px;
                spacing: 14px;

                HorizontalLayout {
                    height: 52px;
                    spacing: 12px;

                    Rectangle {
                        width: 8px;
                        background: #00000000;

                        Rectangle {
                            width: 8px;
                            height: 40px;
                            y: (parent.height - self.height) / 2;
                            border-radius: 4px;
                            background: app_dialog_error ? #ffb4ab : (app_dialog_confirm ? #f6c76d : #9ef0b5);
                        }
                    }

                    TitleBlock {
                        horizontal-stretch: 1;
                        title: app_dialog_title;
                        sub: app_dialog_confirm ? I18n.tr("需要确认", "Confirmation Required", "確認が必要です") : "";
                    }
                }

                ScrollView {
                    height: dialog.text-height;
                    viewport-width: self.width;
                    viewport-height: dialog.natural-text-height;

                    Txt {
                        x: 0px;
                        y: 0px;
                        width: parent.width;
                        height: dialog.natural-text-height;
                        text: app_dialog_text;
                        color: #dbeafe;
                        font-size: 14px;
                        font-weight: 500;
                        wrap: char-wrap;
                    }
                }

                if app_dialog_input : InputBox {
                    enabled: true;

                    LineEdit {
                        x: 14px;
                        y: 8px;
                        width: parent.width - 28px;
                        height: parent.height - 16px;
                        text: app_dialog_input_text;
                        placeholder-text: I18n.tr("游戏根目录", "Game root", "ゲームルート");
                        font-family: "Maple Mono NF CN";
                        font-size: 14px;
                        edited(text) => { root.app_dialog_input_text = text; }
                    }
                }

                HorizontalLayout {
                    height: 58px;
                    spacing: 12px;

                    Rectangle { horizontal-stretch: 1; background: #00000000; }

                    if app_dialog_confirm || app_dialog_input : Action {
                        width: 132px;
                        label: app_dialog_secondary_text;
                        sub: "";
                        accent: #ffb4ab;
                        clicked => { root.app_dialog_secondary(); }
                    }

                    Action {
                        width: 156px;
                        label: app_dialog_primary_text;
                        sub: "";
                        accent: app_dialog_error ? #ffb4ab : #62e2c1;
                        clicked => { root.app_dialog_primary(); }
                    }
                }
            }
        }
    }
}

export component InstallProgressDialog inherits Rectangle {
    in property <bool> busy;
    in property <bool> cancelable: true;
    in property <string> dialog_title: I18n.tr("任务进度", "Task Progress", "タスク進捗");
    in property <float> progress: 0.0;
    in property <string> percent: "0%";
    in property <string> title: "";
    in property <string> detail: "";
    in property <int> detail_lines: 1;
    callback close_clicked();
    callback cancel_clicked();

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: #05070bd9;

        dialog := Panel {
            property <length> max-panel-width: root.width > 64px ? root.width - 64px : root.width;
            property <length> max-panel-height: root.height > 64px ? root.height - 64px : root.height;
            property <length> progress-height: 78px + min(detail_lines <= 1 ? 18px : detail_lines * 18px, 88px);
            property <length> natural-height: 166px + progress-height;

            width: min(560px, max-panel-width);
            height: min(max-panel-height, natural-height);
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            radius: 24px;

            VerticalLayout {
                padding: 24px;
                spacing: 14px;

                TitleBlock {
                    title: root.dialog_title;
                    sub: "";
                }

                ProgressBox {
                    shown: true;
                    progress: root.progress;
                    percent: root.percent;
                    title: root.title;
                    detail: root.detail;
                    detail-lines: root.detail_lines;
                }

                HorizontalLayout {
                    height: 58px;
                    spacing: 12px;

                    Rectangle { horizontal-stretch: 1; background: #00000000; }

                    Action {
                        width: 156px;
                        label: busy ? (cancelable ? I18n.tr("取消", "Cancel", "キャンセル") : I18n.tr("处理中", "Working", "処理中")) : I18n.tr("完成", "Done", "完了");
                        sub: "";
                        enabled: !busy || cancelable;
                        accent: busy ? #ffb4ab : #62e2c1;
                        clicked => {
                            if busy && cancelable {
                                root.cancel_clicked();
                            } else if !busy {
                                root.close_clicked();
                            }
                        }
                    }
                }
            }
        }
    }
}
