export component Txt inherits Text {
    font-family: "Microsoft YaHei UI";
    letter-spacing: 0px;
}

// 主页面面板和弹窗主体使用的深色圆角容器。
export component Panel inherits Rectangle {
    in property <brush> fill: #151922;
    in property <brush> stroke: #273041;
    in property <length> radius: 18px;

    background: fill;
    border-color: stroke;
    border-width: 1px;
    border-radius: radius;
    clip: true;

    @children
}

// 页面和面板头部使用的统一标题/副标题块。
export component TitleBlock inherits Rectangle {
    in property <string> title;
    in property <string> sub: "";

    height: sub == "" ? 32px : 52px;
    background: #00000000;

    VerticalLayout {
        alignment: start;
        spacing: 3px;

        Txt {
            text: title;
            color: #eef4fb;
            font-size: 22px;
            font-weight: 700;
        }

        if sub != "" : Txt {
            text: sub;
            color: #95a3b8;
            font-size: 12px;
            font-weight: 500;
        }
    }
}

// 顶部栏展示的紧凑状态标签。
export component StatusTag inherits Rectangle {
    in property <string> title;
    in property <string> sub;
    in property <brush> accent: #62e2c1;

    height: 42px;
    min-width: 144px;
    border-radius: 12px;
    border-width: 1px;
    border-color: #273041;
    background: #0f131a;
    opacity: 1.0;

    animate opacity { duration: 420ms; }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 12px;
        spacing: 9px;

        Rectangle {
            width: 5px;
            background: #00000000;

            Rectangle {
                width: parent.width;
                height: 24px;
                y: (parent.height - self.height) / 2;
                border-radius: 3px;
                background: accent;
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 0px;
            horizontal-stretch: 1;

            Txt {
                text: title;
                color: #eef4fb;
                font-size: 13px;
                font-weight: 700;
            }

            Txt {
                text: sub;
                color: #95a3b8;
                font-size: 11px;
                font-weight: 500;
            }
        }
    }
}

// 所有顶级页面共用的顶部导航按钮。
export component NavTab inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    callback clicked;

    height: 42px;
    border-radius: 14px;
    border-width: 1px;
    border-color: selected ? #62e2c1 : (touch.has-hover ? #54617a : #273041);
    background: selected ? #103b34 : (touch.has-hover ? #1d2531 : #0f131a);

    animate background { duration: 120ms; }
    animate border-color { duration: 120ms; }

    Txt {
        text: label;
        color: selected ? #c7fff2 : #c7d1df;
        font-size: 14px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => { parent.clicked(); }
    }
}

// 带竖向强调条的主/次操作按钮。
export component Action inherits Rectangle {
    in property <string> label;
    in property <string> sub: "";
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <brush> accent: #62e2c1;
    callback clicked;

    height: primary ? 88px : 54px;
    border-radius: primary ? 22px : 14px;
    border-width: primary ? 0px : 1px;
    border-color: enabled ? (touch.has-hover ? accent : #344056) : #273041;
    background: enabled
        ? (primary
            ? (touch.pressed ? #43bfa3 : (touch.has-hover ? #82f6da : accent))
            : (touch.pressed ? #202a38 : (touch.has-hover ? #1d2531 : #0f131a)))
        : #0f131a88;

    animate background { duration: 140ms; }
    animate border-color { duration: 140ms; }

    HorizontalLayout {
        padding-left: primary ? 22px : 14px;
        padding-right: primary ? 22px : 14px;
        spacing: 12px;

        Rectangle {
            width: primary ? 10px : 6px;
            background: #00000000;

            Rectangle {
                width: parent.width;
                height: primary ? 54px : 28px;
                y: (parent.height - self.height) / 2;
                border-radius: 4px;
                background: enabled ? (primary ? #08231d : accent) : #657285;
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 2px;
            horizontal-stretch: 1;

            Txt {
                text: label;
                color: enabled ? (primary ? #08231d : #eef4fb) : #687589;
                font-size: primary ? 23px : 14px;
                font-weight: 700;
                horizontal-stretch: 1;
            }

            if sub != "" : Txt {
                text: sub;
                color: enabled ? (primary ? #08231d : #95a3b8) : #687589;
                font-size: 12px;
                font-weight: 500;
                horizontal-stretch: 1;
            }
        }
    }

    touch := TouchArea {
        enabled: parent.enabled;
        clicked => { parent.clicked(); }
    }
}

// 用于路径、状态和诊断信息的标签+值容器。
export component InfoBox inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <brush> accent: #62e2c1;
    in property <length> box-height: 88px;

    height: box-height;
    border-radius: 14px;
    border-width: 1px;
    border-color: #273041;
    background: #0f131a;
    clip: true;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 4px;
            background: accent;
        }

        VerticalLayout {
            alignment: start;
            padding-left: 14px;
            padding-right: 14px;
            padding-top: 11px;
            padding-bottom: 11px;
            spacing: 6px;

            Txt {
                text: label;
                color: accent;
                font-size: 11px;
                font-weight: 700;
            }

            Txt {
                text: value;
                color: #eef4fb;
                font-size: 14px;
                font-weight: 500;
                wrap: word-wrap;
            }
        }
    }
}

// 带边框的输入背景；真正的文本编辑交给 LineEdit。
export component InputBox inherits Rectangle {
    in property <bool> enabled: true;

    height: 52px;
    border-radius: 14px;
    border-width: 1px;
    border-color: enabled ? #54617a : #273041;
    background: enabled ? #0f131a : #0f131a88;

    @children
}

// 自绘单行输入框，避免系统原生输入框和深色界面风格不一致。
export component TextField inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder: "";
    in property <bool> enabled: true;
    in property <InputType> input-type: InputType.text;
    callback accepted;
    callback edited(text: string);

    height: 46px;
    border-radius: 14px;
    border-width: 1px;
    border-color: enabled ? (input.has-focus ? #62e2c1 : #344056) : #273041;
    background: enabled ? #0f131a : #0f131a88;

    animate border-color { duration: 120ms; }
    animate background { duration: 120ms; }

    if text == "" && !input.has-focus : Txt {
        x: 14px;
        y: 0px;
        width: parent.width - 28px;
        height: parent.height;
        text: placeholder;
        color: #77849a;
        font-size: 13px;
        font-weight: 500;
        vertical-alignment: center;
        wrap: no-wrap;
    }

    input := TextInput {
        x: 14px;
        y: 0px;
        width: parent.width - 28px;
        height: parent.height;
        text <=> root.text;
        enabled: root.enabled;
        input-type: root.input-type;
        color: root.enabled ? #eef4fb : #687589;
        selection-background-color: #62e2c1;
        selection-foreground-color: #08231d;
        font-family: "Microsoft YaHei UI";
        font-size: 14px;
        font-weight: 500;
        letter-spacing: 0px;
        vertical-alignment: center;
        accepted => { root.accepted(); }
        edited => { root.edited(root.text); }
    }
}

// VNT 服务器地址下拉框，使用自绘列表保持和主界面一致。
export component ServerDropdown inherits Rectangle {
    in-out property <string> value;
    in property <[string]> options;
    in property <bool> enabled: true;
    in-out property <bool> expanded: false;
    callback selected(value: string);

    height: 46px;
    background: #00000000;

    closed := Rectangle {
        width: parent.width;
        height: 46px;
        border-radius: 14px;
        border-width: 1px;
        border-color: enabled ? (touch.has-hover ? #62e2c1 : #344056) : #273041;
        background: enabled ? (touch.has-hover ? #151c27 : #0f131a) : #0f131a88;

        animate background { duration: 120ms; }
        animate border-color { duration: 120ms; }

        Txt {
            x: 14px;
            y: 0px;
            width: parent.width - 54px;
            height: parent.height;
            text: value == "" ? "选择服务器地址" : value;
            color: value == "" ? #77849a : #eef4fb;
            font-size: 14px;
            font-weight: 600;
            vertical-alignment: center;
            wrap: no-wrap;
        }

        Txt {
            x: parent.width - 40px;
            y: 0px;
            width: 26px;
            height: parent.height;
            text: "▼";
            color: enabled ? #95a3b8 : #54617a;
            font-size: 10px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        touch := TouchArea {
            enabled: root.enabled;
            clicked => {
                root.expanded = true;
                popup.show();
            }
        }
    }

    popup := PopupWindow {
        x: 0px;
        y: 50px;
        width: root.width;
        height: 8px + 40px * root.options.length;
        close-policy: close-on-click-outside;

        Rectangle {
            width: parent.width;
            height: parent.height;
            border-radius: 14px;
            border-width: 1px;
            border-color: #344056;
            background: #101721;
            clip: true;

            for option[index] in root.options : Rectangle {
                x: 4px;
                y: 4px + 40px * index;
                width: parent.width - 8px;
                height: 36px;
                border-radius: 11px;
                background: option == root.value ? #103b34 : (item-touch.has-hover ? #1d2531 : #00000000);

                Txt {
                    x: 12px;
                    y: 0px;
                    width: parent.width - 24px;
                    height: parent.height;
                    text: option;
                    color: option == root.value ? #c7fff2 : #dbeafe;
                    font-size: 13px;
                    font-weight: option == root.value ? 800 : 600;
                    vertical-alignment: center;
                    wrap: no-wrap;
                }

                item-touch := TouchArea {
                    clicked => {
                        root.value = option;
                        root.expanded = false;
                        root.selected(option);
                        popup.close();
                    }
                }
            }
        }
    }
}

// 带强调条的设置/状态行。
export component DetailRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <brush> accent: #62e2c1;

    height: 76px;
    border-radius: 14px;
    border-width: 1px;
    border-color: #273041;
    background: #0f131a;
    clip: true;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 14px;
        spacing: 12px;

        Rectangle {
            width: 6px;
            background: #00000000;

            Rectangle {
                width: parent.width;
                height: 40px;
                y: (parent.height - self.height) / 2;
                border-radius: 3px;
                background: accent;
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 5px;
            horizontal-stretch: 1;

            Txt {
                text: label;
                color: accent;
                font-size: 11px;
                font-weight: 800;
                horizontal-stretch: 1;
            }

            Txt {
                text: value;
                color: #eef4fb;
                font-size: 13px;
                font-weight: 500;
                wrap: word-wrap;
                horizontal-stretch: 1;
            }
        }
    }
}

// 供 VNT 页面使用的紧凑双状态选项。
export component OptionSwitch inherits Rectangle {
    in property <bool> checked: false;
    in property <bool> enabled: true;
    in property <string> on-label;
    in property <string> off-label;
    in property <string> sub;
    callback toggled(value: bool);

    height: 48px;
    border-radius: 14px;
    border-width: 1px;
    border-color: enabled ? (checked ? #62e2c1 : (touch.has-hover ? #54617a : #344056)) : #273041;
    background: enabled ? (checked ? #10241f : (touch.has-hover ? #151c27 : #0f131a)) : #0f131a88;

    animate background { duration: 140ms; }
    animate border-color { duration: 140ms; }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 12px;
        spacing: 12px;

        VerticalLayout {
            alignment: center;
            spacing: 2px;
            horizontal-stretch: 1;

            Txt {
                text: checked ? on-label : off-label;
                color: enabled ? (checked ? #c7fff2 : #eef4fb) : #687589;
                font-size: 14px;
                font-weight: 800;
                horizontal-stretch: 1;
                wrap: no-wrap;
            }

            Txt {
                text: sub;
                color: enabled ? (checked ? #8ddfc8 : #8793a6) : #54617a;
                font-size: 10px;
                font-weight: 600;
                horizontal-stretch: 1;
                wrap: no-wrap;
            }
        }

        Rectangle {
            width: 44px;
            background: #00000000;

            Rectangle {
                width: 42px;
                height: 22px;
                x: 1px;
                y: (parent.height - self.height) / 2;
                border-radius: 11px;
                border-width: 1px;
                border-color: enabled ? (checked ? #62e2c1 : #54617a) : #273041;
                background: enabled ? (checked ? #62e2c1 : #263145) : #1a202b;

                animate background { duration: 140ms; }
                animate border-color { duration: 140ms; }

                Rectangle {
                    width: 16px;
                    height: 16px;
                    x: checked ? 22px : 3px;
                    y: 2px;
                    border-radius: 8px;
                    background: enabled ? (checked ? #08231d : #c7d1df) : #657285;

                    animate x { duration: 120ms; easing: ease-out; }
                    animate background { duration: 120ms; }
                }
            }
        }
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.toggled(!root.checked); }
    }
}
