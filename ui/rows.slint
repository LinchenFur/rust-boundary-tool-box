import { Txt } from "components.slint";
import { I18n } from "i18n.slint";

export component PortLine inherits Rectangle {
    in property <string> label;
    in property <string> detail;
    in property <int> pid: 0;
    in property <bool> busy: false;
    in property <bool> occupied: false;
    in property <bool> expected: false;
    callback close_clicked();

    property <brush> status-accent: occupied ? (expected ? #8ecbff : #ffb4ab) : #9ef0b5;
    property <brush> status-fill: occupied ? (expected ? #0d2238 : #241217) : #0f131a;
    property <brush> status-text: occupied ? (expected ? #dbeafe : #ffd9d3) : #95a3b8;

    height: 62px;
    background: #00000000;

    Rectangle {
        width: parent.width;
        height: 56px;
        y: 3px;
        border-radius: 14px;
        border-width: 1px;
        border-color: occupied ? status-accent : #344056;
        background: status-fill;

        HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            spacing: 12px;

            Rectangle {
                width: 6px;
                background: #00000000;

                Rectangle {
                    width: parent.width;
                    height: 30px;
                    y: (parent.height - self.height) / 2;
                    border-radius: 3px;
                    background: status-accent;
                }
            }

            Txt {
                text: label;
                min-width: 88px;
                color: #eef4fb;
                font-size: 14px;
                font-weight: 700;
                vertical-alignment: center;
            }

            Txt {
                text: detail;
                color: status-text;
                font-size: 12px;
                font-weight: 500;
                horizontal-stretch: 1;
                vertical-alignment: center;
            }

            if occupied && pid > 0 : Rectangle {
                width: 98px;
                background: #00000000;

                close-button := Rectangle {
                    width: 90px;
                    height: 34px;
                    x: parent.width - self.width;
                    y: (parent.height - self.height) / 2;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: !busy ? status-accent : #344056;
                    background: !busy
                        ? (expected ? (close-touch.has-hover ? #16344f : #101f32) : (close-touch.has-hover ? #4a1d18 : #2a1719))
                        : #101721;

                    animate background { duration: 120ms; }
                    animate border-color { duration: 120ms; }

                    Txt {
                        text: I18n.tr("关闭进程", "Stop Process", "プロセス停止");
                        color: !busy ? status-text : #657285;
                        font-size: 11px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    close-touch := TouchArea {
                        enabled: !busy;
                        clicked => { root.close_clicked(); }
                    }
                }
            }

            if !occupied || pid <= 0 : Txt {
                text: occupied ? I18n.tr("占用", "Busy", "使用中") : I18n.tr("空闲", "Free", "空き");
                min-width: 52px;
                color: status-accent;
                font-size: 12px;
                font-weight: 800;
                horizontal-alignment: right;
                vertical-alignment: center;
            }
        }
    }
}

// 单个远程社区服行。
export component ServerLine inherits Rectangle {
    in property <string> name;
    in property <string> address;
    in property <string> meta;
    in property <string> state;
    in property <string> players;
    in property <bool> active: false;

    height: 66px;
    background: #00000000;

    Rectangle {
        width: parent.width;
        height: 60px;
        border-radius: 14px;
        border-width: 1px;
        border-color: active ? #9ef0b5 : #344056;
        background: active ? #0d2d1a : #0f131a;

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            spacing: 12px;

            Rectangle {
                width: 6px;
                background: #00000000;

                Rectangle {
                    width: parent.width;
                    height: 32px;
                    y: (parent.height - self.height) / 2;
                    border-radius: 3px;
                    background: active ? #9ef0b5 : #a8d8ff;
                }
            }

            VerticalLayout {
                alignment: center;
                spacing: 3px;
                horizontal-stretch: 1;

                Txt {
                    text: name;
                    color: #eef4fb;
                    font-size: 14px;
                    font-weight: 700;
                    horizontal-stretch: 1;
                    wrap: no-wrap;
                }

                Txt {
                    text: address + "  /  " + meta;
                    color: #95a3b8;
                    font-size: 12px;
                    font-weight: 500;
                    horizontal-stretch: 1;
                    wrap: no-wrap;
                }
            }

            VerticalLayout {
                alignment: center;
                spacing: 3px;
                min-width: 104px;

                Txt {
                    text: players;
                    color: active ? #ddffe6 : #dbeafe;
                    font-size: 14px;
                    font-weight: 800;
                    horizontal-alignment: right;
                }

                Txt {
                    text: state;
                    color: active ? #9ef0b5 : #95a3b8;
                    font-size: 11px;
                    font-weight: 600;
                    horizontal-alignment: right;
                }
            }
        }
    }
}

// 自定义全盘扫描弹窗中的单个盘符行。
export component DriveLine inherits Rectangle {
    in property <string> label;
    in property <bool> checked: false;
    callback toggled();

    height: 58px;
    background: #00000000;

    card := Rectangle {
        y: 4px;
        width: parent.width;
        height: 50px;
        border-radius: 15px;
        border-width: 1px;
        border-color: checked ? #9ef0b5 : (touch.has-hover ? #54617a : #344056);
        background: checked ? #103821 : (touch.has-hover ? #161f2a : #0f131a);

        animate background { duration: 120ms; }
        animate border-color { duration: 120ms; }

        HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            spacing: 12px;

            Rectangle {
                width: 22px;
                background: #00000000;

                Rectangle {
                    width: 22px;
                    height: 22px;
                    y: (parent.height - self.height) / 2;
                    border-radius: 7px;
                    border-width: 2px;
                    border-color: checked ? #9ef0b5 : #54617a;
                    background: checked ? #9ef0b5 : #00000000;
                }
            }

            VerticalLayout {
                alignment: center;
                spacing: 2px;
                horizontal-stretch: 1;

                Txt {
                    text: label;
                    color: #eef4fb;
                    font-size: 15px;
                    font-weight: 700;
                    horizontal-stretch: 1;
                }

                Txt {
                    text: checked ? I18n.tr("已选择", "Selected", "選択済み") : I18n.tr("未选择", "Not selected", "未選択");
                    color: checked ? #9ef0b5 : #95a3b8;
                    font-size: 11px;
                    font-weight: 500;
                    horizontal-stretch: 1;
                }
            }
        }
    }

    touch := TouchArea {
        clicked => { parent.toggled(); }
    }
}

export component VntPeerLine inherits Rectangle {
    in property <string> name;
    in property <string> address;
    in property <string> detail;
    in property <bool> online: false;

    height: 70px;
    background: #00000000;

    Rectangle {
        width: parent.width;
        height: 64px;
        y: 3px;
        border-radius: 15px;
        border-width: 1px;
        border-color: online ? #9ef0b5 : #344056;
        background: online ? #0c2b1b : #0f131a;

        HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            spacing: 12px;

            Rectangle {
                width: 6px;
                background: #00000000;

                Rectangle {
                    width: parent.width;
                    height: 34px;
                    y: (parent.height - self.height) / 2;
                    border-radius: 3px;
                    background: online ? #9ef0b5 : #54617a;
                }
            }

            VerticalLayout {
                alignment: center;
                spacing: 3px;
                horizontal-stretch: 1;

                Txt {
                    text: name;
                    color: #eef4fb;
                    font-size: 14px;
                    font-weight: 800;
                    horizontal-stretch: 1;
                    wrap: no-wrap;
                }

                Txt {
                    text: address == "" ? detail : (detail == "" ? address : address + "  /  " + detail);
                    color: online ? #b9f6c9 : #95a3b8;
                    font-size: 12px;
                    font-weight: 500;
                    horizontal-stretch: 1;
                    wrap: no-wrap;
                }
            }

            Rectangle {
                width: 72px;
                height: 28px;
                y: (parent.height - self.height) / 2;
                border-radius: 10px;
                border-width: 1px;
                border-color: online ? #9ef0b5 : #344056;
                background: online ? #163b25 : #101721;

                Txt {
                    text: online ? I18n.tr("在线", "Online", "オンライン") : I18n.tr("等待", "Waiting", "待機中");
                    color: online ? #9ef0b5 : #95a3b8;
                    font-size: 12px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}

export component VntServerLine inherits Rectangle {
    in property <string> name;
    in property <string> address;
    in property <string> detail;
    in property <bool> online: false;

    height: 76px;
    background: #00000000;

    Rectangle {
        width: parent.width;
        height: 70px;
        y: 3px;
        border-radius: 15px;
        border-width: 1px;
        border-color: online ? #9ef0b5 : #344056;
        background: online ? #0c2b1b : #0f131a;

        HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            spacing: 12px;

            Rectangle {
                width: 6px;
                background: #00000000;

                Rectangle {
                    width: parent.width;
                    height: 34px;
                    y: (parent.height - self.height) / 2;
                    border-radius: 3px;
                    background: online ? #9ef0b5 : #54617a;
                }
            }

            VerticalLayout {
                alignment: center;
                spacing: 2px;
                horizontal-stretch: 1;

                Txt {
                    text: name;
                    color: #eef4fb;
                    font-size: 14px;
                    font-weight: 800;
                    horizontal-stretch: 1;
                    wrap: no-wrap;
                }

                Txt {
                    text: address;
                    color: #95a3b8;
                    font-size: 12px;
                    font-weight: 500;
                    horizontal-stretch: 1;
                    wrap: no-wrap;
                }

                Txt {
                    text: detail;
                    color: online ? #b9f6c9 : #8793a6;
                    font-size: 11px;
                    font-weight: 500;
                    horizontal-stretch: 1;
                    wrap: no-wrap;
                }
            }

            Rectangle {
                width: 72px;
                height: 28px;
                y: (parent.height - self.height) / 2;
                border-radius: 10px;
                border-width: 1px;
                border-color: online ? #9ef0b5 : #344056;
                background: online ? #163b25 : #101721;

                Txt {
                    text: online ? I18n.tr("在线", "Online", "オンライン") : I18n.tr("离线", "Offline", "オフライン");
                    color: online ? #9ef0b5 : #95a3b8;
                    font-size: 12px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
