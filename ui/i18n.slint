export global I18n {
    // 0 = 简体中文，1 = English，2 = 日本語。
    in-out property <int> language: 0;

    public pure function tr(zh: string, en: string, ja: string) -> string {
        return language == 1 ? en : (language == 2 ? ja : zh);
    }

    public pure function language-name(code: int) -> string {
        return code == 1 ? "English" : (code == 2 ? "日本語" : "简体中文");
    }
}
