import { NavTab, Panel, StatusTag, Txt } from "components.slint";
import { I18n } from "i18n.slint";

export component ShellHeader inherits Rectangle {
    in-out property <int> page;
    in property <bool> has_target;
    in property <bool> pulse;
    in property <bool> busy: false;
        HorizontalLayout {
            height: 64px;
            spacing: 14px;

            Panel {
                width: 250px;
                radius: 18px;

                VerticalLayout {
                    padding-left: 18px;
                    padding-right: 18px;
                    spacing: 0px;

                    Txt {
                        text: "BOUNDARY";
                        color: #eef4fb;
                        font-family: "Maple Mono NF CN";
                        font-size: 25px;
                        font-weight: 800;
                    }

                    Txt {
                        text: I18n.tr("社区服工具箱", "Community Toolbox", "コミュニティツール");
                        color: #95a3b8;
                        font-size: 13px;
                        font-weight: 700;
                    }
                }
            }

            NavTab {
                width: 112px;
                label: I18n.tr("启动", "Launch", "起動");
                selected: page == 0;
                enabled: !busy;
                clicked => { root.page = 0; }
            }

            NavTab {
                width: 112px;
                label: I18n.tr("目录", "Path", "パス");
                selected: page == 1;
                enabled: !busy;
                clicked => { root.page = 1; }
            }

            NavTab {
                width: 112px;
                label: I18n.tr("诊断", "Diagnostics", "診断");
                selected: page == 2;
                enabled: !busy;
                clicked => { root.page = 2; }
            }

            NavTab {
                width: 112px;
                label: I18n.tr("联机", "Network", "ネットワーク");
                selected: page == 5;
                enabled: !busy;
                clicked => { root.page = 5; }
            }

            NavTab {
                width: 112px;
                label: I18n.tr("服务器", "Servers", "サーバー");
                selected: page == 4;
                enabled: !busy;
                clicked => { root.page = 4; }
            }

            NavTab {
                width: 112px;
                label: I18n.tr("设置", "Settings", "設定");
                selected: page == 3;
                enabled: !busy;
                clicked => { root.page = 3; }
            }

            Rectangle { horizontal-stretch: 1; background: #00000000; }

            StatusTag {
                title: has_target ? I18n.tr("就绪", "READY", "準備完了") : I18n.tr("等待", "WAIT", "待機");
                sub: has_target
                    ? I18n.tr("目标目录已锁定", "Target path locked", "対象パス設定済み")
                    : I18n.tr("等待目标目录", "Waiting for target", "対象パス待ち");
                accent: has_target ? #9ef0b5 : #f6c76d;
                opacity: has_target ? 1.0 : (pulse ? 0.72 : 1.0);
            }
        }
}
