// Boundary 工具箱的主窗口。
//
// 具体视觉组件拆在 components.slint、rows.slint 和 models.slint 中。

import { PortRow, DriveRow, ServerRow, VntPeerRow } from "models.slint";
import { StartPage } from "pages/start_page.slint";
import { DirectoryPage } from "pages/directory_page.slint";
import { DiagnosticsPage } from "pages/diagnostics_page.slint";
import { VntPage } from "pages/vnt_page.slint";
import { SettingsPage } from "pages/settings_page.slint";
import { ServersPage } from "pages/servers_page.slint";
import { ShellHeader } from "header.slint";
import { AppDialog, DriveScanDialog } from "dialogs.slint";

export component AppWindow inherits Window {
    title: "边境社区服工具箱";
    width: 1260px;
    height: 780px;
    background: #0b0e13;

    // 页面索引：0 启动，1 目录，2 诊断，3 设置，4 服务器，5 VNT 联机。
    property <int> page: 0;

    // 启动页和目录页共享的目录/安装状态。
    in-out property <string> payload_label: "";
    in-out property <string> detected_text: "正在检测 Steam 安装目录...";
    in-out property <string> manual_path: "";
    in-out property <string> target_text: "未解析到有效的安装目录";
    in-out property <bool> auto_mode: true;
    in-out property <bool> keep_topmost: true;
    in-out property <string> hotkey_text: "Ctrl+Alt+F10";
    in-out property <string> status_text: "准备就绪";
    in-out property <string> process_status_text: "运行进程：未检测";
    in-out property <bool> show_logs: false;
    in-out property <string> log_text: "";
    in-out property <bool> busy: false;
    in-out property <bool> pulse: false;
    in-out property <bool> hotkey_listening: false;
    in-out property <bool> show_drive_dialog: false;
    in-out property <bool> show_app_dialog: false;
    in-out property <bool> app_dialog_confirm: false;
    in-out property <bool> app_dialog_input: false;
    in-out property <bool> app_dialog_error: false;
    in-out property <string> app_dialog_title: "";
    in-out property <string> app_dialog_text: "";
    in-out property <string> app_dialog_input_text: "";
    in-out property <string> app_dialog_primary_text: "确定";
    in-out property <string> app_dialog_secondary_text: "取消";
    in-out property <bool> has_target: false;

    // 远程社区服列表状态。
    in-out property <bool> servers_loading: false;
    in-out property <string> server_status_text: "服务器列表：未刷新";

    // 用于 VNT 联机的状态和选项。
    in-out property <string> vnt_server_text: "101.35.230.139:6660";
    in-out property <string> vnt_network_code: "";
    in-out property <string> vnt_password: "";
    in-out property <bool> vnt_no_tun: false;
    in-out property <bool> vnt_compress: false;
    in-out property <bool> vnt_rtx: false;
    in-out property <bool> vnt_busy: false;
    in-out property <bool> vnt_running: false;
    in-out property <string> vnt_status_text: "未连接";
    in-out property <string> vnt_detail_text: "填写网络编号后启动联机平台";
    in-out property <string> vnt_ip_text: "-";
    in-out property <string> vnt_server_status_text: "-";
    in-out property <string> vnt_nat_text: "-";
    in-out property <string> vnt_peer_summary_text: "0 个节点";

    // 列表模型由 Rust 持有并原地更新。
    in-out property <[PortRow]> port_rows;
    in-out property <[DriveRow]> drive_rows;
    in-out property <[ServerRow]> server_rows;
    in-out property <[VntPeerRow]> vnt_peer_rows;

    // 目录选择回调。
    callback browse_clicked();
    callback redetect_clicked();
    callback scan_clicked();
    callback auto_mode_clicked();
    callback manual_mode_clicked();
    callback manual_path_changed(text: string);

    // 设置回调。
    callback keep_topmost_toggled(value: bool);
    callback hotkey_text_changed(text: string);
    callback hotkey_captured(text: string, control: bool, alt: bool, shift: bool, meta: bool);

    // 核心操作回调。
    callback install_clicked();
    callback uninstall_clicked();
    callback launch_clicked();
    callback detect_processes_clicked();
    callback stop_processes_clicked();
    callback stop_port_process_clicked(protocol: string, port: int, pid: int);
    callback open_logs_clicked();

    // 远程服务器和 VNT 回调。
    callback refresh_servers_clicked();
    callback vnt_start_clicked();
    callback vnt_stop_clicked();
    callback vnt_refresh_clicked();
    callback toggle_logs_clicked();

    // 自定义弹窗回调。
    callback drive_toggled(index: int, checked: bool);
    callback drive_confirmed();
    callback drive_cancelled();
    callback app_dialog_primary();
    callback app_dialog_secondary();

    VerticalLayout {
        padding: 18px;
        spacing: 14px;

        ShellHeader {
            height: 64px;
            page <=> root.page;
            has_target: root.has_target;
            pulse: root.pulse;
        }

        content := Rectangle {
            vertical-stretch: 1;
            background: #00000000;

        if page == 0 : StartPage {
            width: parent.width;
            height: parent.height;
            has_target: root.has_target;
            busy: root.busy;
            auto_mode: root.auto_mode;
            status_text: root.status_text;
            target_text: root.target_text;
            detected_text: root.detected_text;
            launch_clicked => { root.launch_clicked(); }
            install_clicked => { root.install_clicked(); }
            uninstall_clicked => { root.uninstall_clicked(); }
            scan_clicked => { root.scan_clicked(); }
            goto_directory => { root.page = 1; }
        }

        if page == 1 : DirectoryPage {
            width: parent.width;
            height: parent.height;
            has_target: root.has_target;
            busy: root.busy;
            auto_mode: root.auto_mode;
            manual_path: root.manual_path;
            detected_text: root.detected_text;
            target_text: root.target_text;
            auto_mode_clicked => { root.auto_mode_clicked(); }
            manual_mode_clicked => { root.manual_mode_clicked(); }
            scan_clicked => { root.scan_clicked(); }
            redetect_clicked => { root.redetect_clicked(); }
            browse_clicked => { root.browse_clicked(); }
            manual_path_changed(text) => { root.manual_path_changed(text); }
        }

        if page == 2 : DiagnosticsPage {
            width: parent.width;
            height: parent.height;
            has_target: root.has_target;
            busy: root.busy;
            show_logs: root.show_logs;
            process_status_text: root.process_status_text;
            log_text: root.log_text;
            port_rows: root.port_rows;
            detect_processes_clicked => { root.detect_processes_clicked(); }
            stop_processes_clicked => { root.stop_processes_clicked(); }
            stop_port_process_clicked(protocol, port, pid) => {
                root.stop_port_process_clicked(protocol, port, pid);
            }
            toggle_logs_clicked => { root.toggle_logs_clicked(); }
        }

        if page == 5 : VntPage {
            width: parent.width;
            height: parent.height;
            vnt_server_text <=> root.vnt_server_text;
            vnt_network_code <=> root.vnt_network_code;
            vnt_password <=> root.vnt_password;
            vnt_no_tun <=> root.vnt_no_tun;
            vnt_compress <=> root.vnt_compress;
            vnt_rtx <=> root.vnt_rtx;
            vnt_busy: root.vnt_busy;
            vnt_running: root.vnt_running;
            vnt_status_text: root.vnt_status_text;
            vnt_detail_text: root.vnt_detail_text;
            vnt_ip_text: root.vnt_ip_text;
            vnt_server_status_text: root.vnt_server_status_text;
            vnt_nat_text: root.vnt_nat_text;
            vnt_peer_summary_text: root.vnt_peer_summary_text;
            vnt_peer_rows: root.vnt_peer_rows;
            vnt_start_clicked => { root.vnt_start_clicked(); }
            vnt_stop_clicked => { root.vnt_stop_clicked(); }
            vnt_refresh_clicked => { root.vnt_refresh_clicked(); }
        }

        if page == 3 : SettingsPage {
            width: parent.width;
            height: parent.height;
            hotkey_listening <=> root.hotkey_listening;
            keep_topmost: root.keep_topmost;
            busy: root.busy;
            has_target: root.has_target;
            hotkey_text: root.hotkey_text;
            status_text: root.status_text;
            target_text: root.target_text;
            process_status_text: root.process_status_text;
            server_status_text: root.server_status_text;
            keep_topmost_toggled(value) => { root.keep_topmost_toggled(value); }
            hotkey_captured(text, control, alt, shift, meta) => { root.hotkey_captured(text, control, alt, shift, meta); }
            open_logs_clicked => { root.open_logs_clicked(); }
        }

        if page == 4 : ServersPage {
            width: parent.width;
            height: parent.height;
            servers_loading: root.servers_loading;
            server_status_text: root.server_status_text;
            server_rows: root.server_rows;
            refresh_servers_clicked => { root.refresh_servers_clicked(); }
        }
        }
    }

    if show_drive_dialog : DriveScanDialog {
        width: parent.width;
        height: parent.height;
        busy: root.busy;
        drive_rows: root.drive_rows;
        drive_toggled(index, checked) => { root.drive_toggled(index, checked); }
        drive_confirmed => { root.drive_confirmed(); }
        drive_cancelled => { root.drive_cancelled(); }
    }

    if show_app_dialog : AppDialog {
        width: parent.width;
        height: parent.height;
        app_dialog_confirm: root.app_dialog_confirm;
        app_dialog_input: root.app_dialog_input;
        app_dialog_error: root.app_dialog_error;
        app_dialog_title: root.app_dialog_title;
        app_dialog_text: root.app_dialog_text;
        app_dialog_input_text <=> root.app_dialog_input_text;
        app_dialog_primary_text: root.app_dialog_primary_text;
        app_dialog_secondary_text: root.app_dialog_secondary_text;
        app_dialog_primary => { root.app_dialog_primary(); }
        app_dialog_secondary => { root.app_dialog_secondary(); }
    }
}
