// Boundary 工具箱的主窗口。
//
// 具体视觉组件拆在 components.slint、rows.slint 和 models.slint 中。

import { PortRow, DriveRow, ProxyRow, ServerRow, VntPeerRow, VntServerRow } from "models.slint";
import { StartPage } from "pages/start_page.slint";
import { DirectoryPage } from "pages/directory_page.slint";
import { DiagnosticsPage } from "pages/diagnostics_page.slint";
import { VntPage } from "pages/vnt_page.slint";
import { SettingsPage } from "pages/settings_page.slint";
import { ServersPage } from "pages/servers_page.slint";
import { ShellHeader } from "header.slint";
import { AppDialog, DriveScanDialog, InstallProgressDialog, ProxySelectDialog } from "dialogs.slint";
import { ImageLightbox, MamaButton, Txt, WindowButton } from "components.slint";
import { I18n } from "i18n.slint";

export component AppWindow inherits Window {
    title: I18n.tr("边境社区服工具箱", "Boundary Community Toolbox", "Boundary コミュニティツール");
    width: 1260px;
    height: 780px;
    background: #0b0e13;
    default-font-family: "Maple Mono NF CN";
    no-frame: true;
    resize-border-width: 6px;

    // 页面索引：0 启动，1 目录，2 诊断，3 设置，4 服务器，5 VNT 联机。
    in-out property <int> page: 0;

    // 启动页和目录页共享的目录/安装状态。
    in-out property <string> payload_label: "";
    in-out property <string> detected_text: I18n.tr("正在检测 Steam 安装目录...", "Detecting Steam install path...", "Steam のインストール先を検出中...");
    in-out property <string> manual_path: "";
    in-out property <string> target_text: I18n.tr("未解析到有效的安装目录", "No valid install path resolved", "有効なインストール先が見つかりません");
    in-out property <bool> auto_mode: true;
    in-out property <string> status_text: I18n.tr("准备就绪", "Ready", "準備完了");
    in-out property <string> process_status_text: I18n.tr("运行进程：未检测", "Runtime processes: not checked", "実行中プロセス: 未確認");
    in-out property <bool> show_logs: false;
    in-out property <string> log_text: "";
    in-out property <bool> busy: false;
    in-out property <bool> is_admin: true;
    in-out property <bool> pulse: false;
    in-out property <bool> install_progress_visible: false;
    in-out property <bool> install_progress_cancelable: true;
    in-out property <float> install_progress_value: 0.0;
    in-out property <string> install_progress_percent: "0%";
    in-out property <string> install_progress_title: "";
    in-out property <string> install_progress_detail: "";
    in-out property <int> install_progress_detail_lines: 1;
    in-out property <bool> show_drive_dialog: false;
    in-out property <bool> show_github_proxy_dialog: false;
    in-out property <bool> show_app_dialog: false;
    in-out property <bool> show_mama_image: false;
    in-out property <bool> app_dialog_confirm: false;
    in-out property <bool> app_dialog_input: false;
    in-out property <bool> app_dialog_error: false;
    in-out property <int> app_dialog_text_lines: 1;
    in-out property <string> app_dialog_title: "";
    in-out property <string> app_dialog_text: "";
    in-out property <string> app_dialog_input_text: "";
    in-out property <string> app_dialog_primary_text: I18n.tr("确定", "OK", "OK");
    in-out property <string> app_dialog_secondary_text: I18n.tr("取消", "Cancel", "キャンセル");
    in-out property <bool> has_target: false;

    // 远程社区服列表状态。
    in-out property <bool> servers_loading: false;
    in-out property <string> server_status_text: I18n.tr("服务器列表：未刷新", "Server list: not refreshed", "サーバー一覧: 未更新");
    in-out property <bool> update_checking: false;
    in-out property <string> update_status_text: I18n.tr("更新：未检查", "Update: not checked", "更新: 未確認");
    in-out property <string> github_proxy_text: "";
    in-out property <[ProxyRow]> github_proxy_rows;
    in-out property <bool> github_proxy_loading: false;
    in-out property <string> github_proxy_status_text: "";

    // 用于 VNT 联机的状态和选项。
    in-out property <string> vnt_server_text: "101.35.230.139:6660";
    in-out property <string> vnt_new_server_text: "";
    in-out property <[string]> vnt_server_options;
    in-out property <string> vnt_network_code: "";
    in-out property <string> vnt_password: "";
    in-out property <bool> vnt_no_tun: false;
    in-out property <bool> vnt_compress: false;
    in-out property <bool> vnt_rtx: false;
    in-out property <bool> vnt_busy: false;
    in-out property <bool> vnt_running: false;
    in-out property <string> vnt_status_text: I18n.tr("未连接", "Disconnected", "未接続");
    in-out property <string> vnt_detail_text: I18n.tr("填写网络编号后启动联机平台", "Enter a network code before starting", "ネットワーク番号を入力してから起動してください");
    in-out property <string> vnt_ip_text: "-";
    in-out property <string> vnt_server_status_text: "-";
    in-out property <string> vnt_nat_text: "-";
    in-out property <string> vnt_peer_summary_text: I18n.tr("0 个节点", "0 peers", "0 ノード");
    in-out property <[VntServerRow]> vnt_server_rows;
    in-out property <int> language: 0;
    in-out property <int> language_mode: -1;

    // 列表模型由 Rust 持有并原地更新。
    in-out property <[PortRow]> port_rows;
    in-out property <[DriveRow]> drive_rows;
    in-out property <[ServerRow]> server_rows;
    in-out property <[VntPeerRow]> vnt_peer_rows;

    // 目录选择回调。
    callback browse_clicked();
    callback redetect_clicked();
    callback scan_clicked();
    callback auto_mode_clicked();
    callback manual_mode_clicked();
    callback manual_path_changed(text: string);

    // 核心操作回调。
    callback install_clicked();
    callback uninstall_clicked();
    callback launch_pvp_clicked();
    callback launch_pve_clicked();
    callback detect_processes_clicked();
    callback stop_processes_clicked();
    callback stop_port_process_clicked(protocol: string, port: int, pid: int);
    callback open_logs_clicked();

    // 远程服务器和 VNT 回调。
    callback check_updates_clicked();
    callback refresh_servers_clicked();
    callback github_proxy_changed(proxy: string);
    callback github_proxy_selected(proxy: string);
    callback open_github_proxy_dialog_clicked();
    callback refresh_github_proxies_clicked();
    callback vnt_start_clicked();
    callback vnt_stop_clicked();
    callback vnt_refresh_clicked();
    callback vnt_add_server_clicked(address: string);
    callback vnt_settings_changed();
    callback toggle_logs_clicked();
    callback page_changed(page: int);
    callback language_changed(language: int);

    // 自定义弹窗回调。
    callback drive_toggled(index: int, checked: bool);
    callback drive_confirmed();
    callback drive_cancelled();
    callback github_proxy_dialog_cancelled();
    callback app_dialog_primary();
    callback app_dialog_secondary();
    callback install_progress_closed();
    callback install_progress_cancelled();
    callback window_drag_started();
    callback window_minimize_clicked();
    callback window_close_clicked();

    changed page => { root.page_changed(root.page); }
    changed language => { I18n.language = root.language; }

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: #0b0e13;
        border-color: #273041;
        border-width: 1px;
        clip: true;

        VerticalLayout {
            padding-left: 18px;
            padding-right: 18px;
            padding-bottom: 24px;
            spacing: 14px;

            Rectangle {
                height: 34px;
                background: #00000000;

                HorizontalLayout {
                    padding-left: 4px;
                    spacing: 10px;

                    Rectangle {
                        width: 12px;
                        background: #00000000;

                        Rectangle {
                            width: 8px;
                            height: 8px;
                            x: 2px;
                            y: (parent.height - self.height) / 2;
                            border-radius: 4px;
                            background: #62e2c1;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        background: #00000000;

                        Txt {
                            text: I18n.tr("边境社区服工具箱", "Boundary Community Toolbox", "Boundary コミュニティツール");
                            color: #c7d1df;
                            font-size: 13px;
                            font-weight: 700;
                            vertical-alignment: center;
                        }

                        drag-area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            pointer-event(event) => {
                                if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                                    root.window_drag_started();
                                }
                            }
                        }
                    }

                    WindowButton {
                        label: "−";
                        clicked => { root.window_minimize_clicked(); }
                    }

                    WindowButton {
                        label: "×";
                        danger: true;
                        clicked => { root.window_close_clicked(); }
                    }
                }
            }

            ShellHeader {
                height: 64px;
                page <=> root.page;
                has_target: root.has_target;
                is_admin: root.is_admin;
                pulse: root.pulse;
                busy: root.busy;
            }

            content := Rectangle {
                vertical-stretch: 1;
                background: #00000000;

                StartPage {
                    width: parent.width;
                    height: parent.height;
                    visible: root.page == 0;
                    has_target: root.has_target;
                    busy: root.busy;
                    is_admin: root.is_admin;
                    auto_mode: root.auto_mode;
                    status_text: root.status_text;
                    target_text: root.target_text;
                    detected_text: root.detected_text;
                    launch_pvp_clicked => { root.launch_pvp_clicked(); }
                    launch_pve_clicked => { root.launch_pve_clicked(); }
                    install_clicked => { root.install_clicked(); }
                    uninstall_clicked => { root.uninstall_clicked(); }
                    scan_clicked => { root.scan_clicked(); }
                    goto_directory => { root.page = 1; }
                }

                DirectoryPage {
                    width: parent.width;
                    height: parent.height;
                    visible: root.page == 1;
                    has_target: root.has_target;
                    busy: root.busy;
                    auto_mode: root.auto_mode;
                    manual_path: root.manual_path;
                    detected_text: root.detected_text;
                    target_text: root.target_text;
                    auto_mode_clicked => { root.auto_mode_clicked(); }
                    manual_mode_clicked => { root.manual_mode_clicked(); }
                    scan_clicked => { root.scan_clicked(); }
                    redetect_clicked => { root.redetect_clicked(); }
                    browse_clicked => { root.browse_clicked(); }
                    manual_path_changed(text) => { root.manual_path_changed(text); }
                }

                DiagnosticsPage {
                    width: parent.width;
                    height: parent.height;
                    visible: root.page == 2;
                    has_target: root.has_target;
                    busy: root.busy;
                    show_logs: root.page == 2 && root.show_logs;
                    process_status_text: root.process_status_text;
                    log_text: root.page == 2 && root.show_logs ? root.log_text : "";
                    port_rows: root.page == 2 ? root.port_rows : [];
                    detect_processes_clicked => { root.detect_processes_clicked(); }
                    stop_processes_clicked => { root.stop_processes_clicked(); }
                    stop_port_process_clicked(protocol, port, pid) => {
                        root.stop_port_process_clicked(protocol, port, pid);
                    }
                    toggle_logs_clicked => { root.toggle_logs_clicked(); }
                }

                VntPage {
                    width: parent.width;
                    height: parent.height;
                    visible: root.page == 5;
                    vnt_server_text <=> root.vnt_server_text;
                    vnt_new_server_text <=> root.vnt_new_server_text;
                    vnt_server_options: root.vnt_server_options;
                    vnt_network_code <=> root.vnt_network_code;
                    vnt_password <=> root.vnt_password;
                    vnt_no_tun <=> root.vnt_no_tun;
                    vnt_compress <=> root.vnt_compress;
                    vnt_rtx <=> root.vnt_rtx;
                    vnt_busy: root.vnt_busy;
                    vnt_running: root.vnt_running;
                    vnt_status_text: root.vnt_status_text;
                    vnt_detail_text: root.vnt_detail_text;
                    vnt_ip_text: root.vnt_ip_text;
                    vnt_server_status_text: root.vnt_server_status_text;
                    vnt_nat_text: root.vnt_nat_text;
                    vnt_peer_summary_text: root.vnt_peer_summary_text;
                    vnt_server_rows: root.page == 5 ? root.vnt_server_rows : [];
                    vnt_peer_rows: root.page == 5 ? root.vnt_peer_rows : [];
                    vnt_start_clicked => { root.vnt_start_clicked(); }
                    vnt_stop_clicked => { root.vnt_stop_clicked(); }
                    vnt_refresh_clicked => { root.vnt_refresh_clicked(); }
                    vnt_add_server_clicked(address) => { root.vnt_add_server_clicked(address); }
                    vnt_settings_changed => { root.vnt_settings_changed(); }
                }

                SettingsPage {
                    width: parent.width;
                    height: parent.height;
                    visible: root.page == 3;
                    busy: root.busy;
                    has_target: root.has_target;
                    status_text: root.status_text;
                    target_text: root.target_text;
                    process_status_text: root.process_status_text;
                    server_status_text: root.server_status_text;
                    update_checking: root.update_checking;
                    update_status_text: root.update_status_text;
                    github_proxy_text <=> root.github_proxy_text;
                    github_proxy_loading: root.github_proxy_loading;
                    github_proxy_status_text: root.github_proxy_status_text;
                    language: root.language;
                    language_mode: root.language_mode;
                    open_logs_clicked => { root.open_logs_clicked(); }
                    check_updates_clicked => { root.check_updates_clicked(); }
                    github_proxy_changed(proxy) => { root.github_proxy_changed(proxy); }
                    open_github_proxy_dialog_clicked => { root.open_github_proxy_dialog_clicked(); }
                    refresh_github_proxies_clicked => { root.refresh_github_proxies_clicked(); }
                    language_changed(language) => { root.language_changed(language); }
                }

                ServersPage {
                    width: parent.width;
                    height: parent.height;
                    visible: root.page == 4;
                    servers_loading: root.servers_loading;
                    server_status_text: root.server_status_text;
                    server_rows: root.page == 4 ? root.server_rows : [];
                    refresh_servers_clicked => { root.refresh_servers_clicked(); }
                }

                if root.page == 0 : MamaButton {
                    x: parent.width - self.width - 22px;
                    y: parent.height - self.height - 34px;
                    clicked => { root.show_mama_image = true; }
                }
            }
        }

        if install_progress_visible : InstallProgressDialog {
            width: parent.width;
            height: parent.height;
            busy: root.busy;
            cancelable: root.install_progress_cancelable;
            progress: root.install_progress_value;
            percent: root.install_progress_percent;
            title: root.install_progress_title;
            detail: root.install_progress_detail;
            detail_lines: root.install_progress_detail_lines;
            close_clicked => { root.install_progress_closed(); }
            cancel_clicked => { root.install_progress_cancelled(); }
        }

        if show_drive_dialog : DriveScanDialog {
            width: parent.width;
            height: parent.height;
            busy: root.busy;
            drive_rows: root.drive_rows;
            drive_toggled(index, checked) => { root.drive_toggled(index, checked); }
            drive_confirmed => { root.drive_confirmed(); }
            drive_cancelled => { root.drive_cancelled(); }
        }

        if show_github_proxy_dialog : ProxySelectDialog {
            width: parent.width;
            height: parent.height;
            busy: root.busy;
            loading: root.github_proxy_loading;
            status_text: root.github_proxy_status_text;
            proxy_rows: root.github_proxy_rows;
            proxy_selected(url) => { root.github_proxy_selected(url); }
            proxy_refresh_clicked => { root.refresh_github_proxies_clicked(); }
            proxy_cancelled => { root.github_proxy_dialog_cancelled(); }
        }

        if show_app_dialog : AppDialog {
            width: parent.width;
            height: parent.height;
            app_dialog_confirm: root.app_dialog_confirm;
            app_dialog_input: root.app_dialog_input;
            app_dialog_error: root.app_dialog_error;
            app_dialog_text_lines: root.app_dialog_text_lines;
            app_dialog_title: root.app_dialog_title;
            app_dialog_text: root.app_dialog_text;
            app_dialog_input_text <=> root.app_dialog_input_text;
            app_dialog_primary_text: root.app_dialog_primary_text;
            app_dialog_secondary_text: root.app_dialog_secondary_text;
            app_dialog_primary => { root.app_dialog_primary(); }
            app_dialog_secondary => { root.app_dialog_secondary(); }
        }

        if show_mama_image : ImageLightbox {
            width: parent.width;
            height: parent.height;
            image: @image-url("assets/gm.png");
            closed => { root.show_mama_image = false; }
        }
    }
}
